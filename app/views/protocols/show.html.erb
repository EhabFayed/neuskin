<%# Protocol detail — NeuSkin Clinic (standalone) design port. English / LTR. %>
<% p = @protocol %>

<%# Hero image: map by slug like the _card partial, fallback treatment_room. %>
<% proto_hero_imgs = { "neuskin-method" => "site/protocols/neuskin-method.jpg", "90-day-glow-reset" => "site/protocols/glow-reset.jpg",
                       "brides-180" => "site/protocols/bridal.jpg", "reset-crown" => "site/protocols/hair.jpg",
                       "8-week-sculpt" => "site/protocols/sculpt.jpg", "skin-insider" => "site/protocols/insider.jpg" } %>
<% hero_img = proto_hero_imgs[p.slug] %>
<% for_who = p.who_for.to_s.split(/[.\n]/).first.to_s.strip.presence || "By assessment" %>

<%# 1 · Split hero ---- %>
<section class="split-hero" data-controller="reveal parallax">
  <div class="split-hero-media reveal" data-reveal-target="item" data-parallax data-parallax-speed="0.08">
    <% if hero_img %>
      <%= image_tag hero_img, alt: p.name, class: "kb" %>
    <% else %>
      <%= ns_image_tag :treatment_room, alt: p.name, class: "kb" %>
    <% end %>
  </div>
  <div class="split-hero-copy">
    <span class="eyebrow reveal" data-reveal-target="item"><%= p.meta %></span>
    <h1><span data-reveal="mask" data-reveal-delay="120"><span><bdi><%= p.name %><% if p.trademark %><span class="tm">™</span><% end %></bdi></span></span></h1>
    <p class="lead reveal d2" data-reveal-target="item"><%= p.promise %></p>
    <ul class="specs reveal d3" data-reveal-target="item">
      <li><span class="k">Duration</span><span class="v"><%= p.duration %></span></li>
      <li><span class="k">Format</span><span class="v">Doctor-led · personalised</span></li>
      <li><span class="k">For</span><span class="v"><%= for_who %></span></li>
    </ul>
    <p class="reveal d4" data-reveal-target="item"><%= link_to "Request your plan", inquire_path(codeword: p.codeword, persona: p.persona), class: "btn" %></p>
  </div>
</section>

<%# 2 · Who it's for ---- %>
<% signs = [
     ["01", "You want to know what your skin actually needs — measured, not guessed."],
     ["02", "You'd rather follow one sequenced plan than collect single treatments."],
     ["03", "You value discretion, and a doctor who will tell you what to skip."]
   ] %>
<section class="section section--surface proto-detail" data-controller="reveal">
  <div class="section-inner split">
    <div class="split-text reveal" data-reveal-target="item">
      <span class="eyebrow">Who it's for</span>
      <p class="lead"><%= p.who_for %></p>
    </div>
    <div class="split-text">
      <ul class="rows">
        <% signs.each_with_index do |(n, t), i| %>
          <li data-reveal="left" data-reveal-delay="<%= 120 + i * 140 %>"><span class="n"><%= n %></span><span class="t"><%= t %></span></li>
        <% end %>
      </ul>
      <p class="sign" style="font-style:italic;margin-top:24px" data-reveal="fade" data-reveal-delay="<%= 120 + signs.size * 140 %>">This protocol is not for everyone — and that is intentional.</p>
    </div>
  </div>
</section>

<%# 3 · What's inside (staged timeline) ---- %>
<section class="section proto-detail" data-controller="reveal">
  <div class="section-inner">
    <div class="sec-head">
      <span class="eyebrow" data-reveal="fade">What's inside</span>
      <h2 data-reveal="mask" data-reveal-delay="120"><span><%= p.scope %></span></h2>
    </div>
    <% if p.stages.any? %>
    <div class="stages">
      <% p.stages.each_with_index do |stage, i| %>
        <div class="stage" data-reveal="up" data-reveal-delay="<%= 160 + i * 150 %>">
          <span class="wk"><%= p.loc(stage, "week") %></span>
          <h3><%= p.loc(stage, "title") %></h3>
          <p><%= p.loc(stage, "body") %></p>
        </div>
      <% end %>
    </div>
    <% end %>
    <p class="note" data-reveal="fade" data-reveal-delay="<%= 160 + p.stages.size * 150 %>" style="margin-top:46px">Final protocol scope is confirmed during your NeuSkin Method™ assessment. All treatments are personalised.</p>
  </div>
</section>

<%# 4 · What's not included ---- %>
<% exclusions = p.excludes.to_s.split(/[.;\n]/).map(&:strip).reject(&:blank?) %>
<% exclusions = [p.excludes.to_s.strip] if exclusions.empty? %>
<section class="section section--surface proto-detail" data-controller="reveal">
  <div class="section-inner split">
    <div class="split-text">
      <span class="eyebrow" data-reveal="fade">What's not included</span>
      <h2 data-reveal="mask" data-reveal-delay="120"><span>Honesty, set early.</span></h2>
    </div>
    <div class="split-text">
      <ul class="exclude">
        <% exclusions.each_with_index do |item, i| %>
          <li data-reveal="left" data-reveal-delay="<%= 160 + i * 130 %>"><%= item %></li>
        <% end %>
      </ul>
    </div>
  </div>
</section>

<%# 5 · The patient journey — expanding image panels, same component as the
      home "Three pillars of our promise" (ns-expand: hovered card grows and
      its photo zooms; first panel holds the expansion at rest). %>
<section id="patient-journey" class="section section--light" data-controller="reveal">
  <div class="section-inner">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="eyebrow">The patient journey</span>
    </div>
    <div class="ns-expand reveal d1" data-reveal-target="item">
      <% [["01 — Step", "Inquire", "A private message, reviewed personally.",  "site/space/waiting-lounge.webp"],
          ["02 — Step", "Consult", "A doctor-led diagnostic assessment.",      "site/space/consultation.jpg"],
          ["03 — Step", "Plan",    "A written, sequenced roadmap.",            "site/space/private-suite.webp"],
          ["04 — Step", "Treat",   "Sessions, reviewed each quarter.",         "site/space/treatment.webp"]].each do |num, title, body, img| %>
        <div class="ns-panel">
          <%= image_tag img, alt: title %>
          <div class="ns-panel-copy">
            <span class="num"><%= num %></span>
            <h3><%= title %></h3>
            <p><%= body %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# 6 · One consented patient story ---- %>
<% if p.patient_story.present? && p.patient_story["quote_en"].present? %>
  <section class="section section--surface proto-story" data-controller="reveal">
    <div class="section-inner">
      <div class="pull-band">
        <blockquote data-reveal="scale"><%= p.patient_story["quote_en"] %></blockquote>
        <p class="by" data-reveal="fade" data-reveal-delay="260">— <%= p.patient_story["initials"] %> · <%= p.name %> · <%= p.patient_story["year"] %></p>
      </div>
    </div>
  </section>
<% end %>

<%# 7 · Frequently asked ---- %>
<% if p.faqs.present? %>
  <section class="section" data-controller="reveal">
    <div class="section-inner">
      <div class="sec-head reveal" data-reveal-target="item">
        <span class="eyebrow">Frequently asked</span>
      </div>
      <div class="faq-group">
        <% p.faqs.each_with_index do |faq, i| %>
          <details class="faq" data-reveal="up" data-reveal-delay="<%= 140 + i * 120 %>">
            <summary><%= p.loc(faq, "q") %> <span class="sign">+</span></summary>
            <div class="faq-a"><%= p.loc(faq, "a") %></div>
          </details>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# 8 · Final CTA + WhatsApp codeword ---- %>
<section class="cta-center cta-center--tight orn-host" data-controller="reveal">
  <%= render "shared/orn", variant: "rings", pos: "halo", size: 380 %>
  <h2 data-reveal="mask"><span>Begin <%= p.name %>.</span></h2>
  <p data-reveal="up" data-reveal-delay="160">Send the codeword <strong><%= p.codeword %></strong> on WhatsApp for a private inquiry.</p>
  <p data-reveal="up" data-reveal-delay="300">
    <a class="btn" href="<%= whatsapp_url(codeword: p.codeword) %>" target="_blank" rel="noopener">Send "<%= p.codeword %>"</a>
  </p>
</section>
