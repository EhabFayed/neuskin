<%# Protocols Hub (§06): hero · "I'm here because…" filter · card grid. %>

<section class="section protocols-hero" data-controller="reveal">
  <div class="wrap narrow" style="text-align:center">
    <div class="reveal d1" data-reveal-target="item">
      <%= image_tag "site/icons/machine.jpg", class: "icon-3d", alt: "" %>
    </div>
    <span class="label reveal d2" data-reveal-target="item"><%= t("protocols.eyebrow_tagline") %></span>
    <h1 class="protocols-title reveal d3" data-reveal-target="item" dir="<%= loc_dir %>">
      <%= loc(ar: t("protocols.hub_title"), en: t("protocols.hub_title")) %>
    </h1>
  </div>
</section>

<section class="section section--deep protocols-hub" style="padding-block-start: 20px;" data-controller="reveal filter">
  <div class="wrap">

    <%# Smart filter: visitor picks "I'm here because…" → cards filter by persona. %>
    <div class="filter reveal" data-reveal-target="item">
      <span class="filter-lead" dir="<%= loc_dir %>"><%= t("protocols.hub_filter_lead") %></span>
      <div class="filter-chips" role="group" aria-label="Filter protocols">
        <% %w[all bride tired hair maintain unsure].each do |persona| %>
          <button type="button" class="chip<%= " is-active" if persona == "all" %>" data-action="filter#select" data-filter-persona-param="<%= persona %>" dir="<%= loc_dir %>"><%= t("protocols.hub_chips.#{persona}") %></button>
        <% end %>
      </div>
    </div>

    <div class="protocols">
      <% @protocols.each do |protocol| %>
        <div class="filter-item" data-filter-target="item" data-persona="<%= protocol.persona %>">
          <%= render "protocols/card", protocol: protocol %>
        </div>
      <% end %>
    </div>

    <p class="hub-closing reveal" data-reveal-target="item" dir="<%= loc_dir %>">
      <%= t("protocols.hub_closing") %>
    </p>

    <%= render "shared/doctor_note", key: "protocols" %>
  </div>
</section>
