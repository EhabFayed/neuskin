<%# Protocols Hub — NeuSkin Clinic (standalone) design port. English / LTR. %>

<%# ---- Hero (atmospheric: photo bleeds through under the radial glow).
      The background image is the protocols_hero section image in the
      dashboard; the static asset is only the fallback. %>
<section class="page-hero has-bg" data-controller="reveal"
         style="--hero-bg: url('<%= sec_image("protocols_index", "protocols_hero", :protocols_hero) %>')">
  <div class="section-inner">
    <span class="eyebrow reveal" data-reveal-target="item"><%= sec_text("protocols_index", "protocols_hero", "eyebrow").presence || "The Protocols" %></span>
    <h1>
      <span data-reveal="mask" data-reveal-delay="120"><span><%= sec_text("protocols_index", "protocols_hero", "title_1").presence || "Six named protocols." %></span></span>
      <span class="em" data-reveal="mask" data-reveal-delay="240"><span><%= sec_text("protocols_index", "protocols_hero", "title_em").presence || "One philosophy. Zero menu pricing." %></span></span>
    </h1>
    <p class="lead reveal d2" data-reveal-target="item">
      <%= sec_text("protocols_index", "protocols_hero", "lead").presence || "NeuSkin works in protocols, not à-la-carte treatments — sequenced plans with a beginning, a measured middle, and a review built in. Six named programmes, one philosophy, and never a price list." %>
    </p>
  </div>
</section>

<%# ---- "I'm here because…" filter + card grid ---- %>
<section class="section section--surface" data-controller="reveal filter">
  <div class="section-inner">
    <div class="reveal" data-reveal-target="item">
      <span class="eyebrow"><%= sec_text("protocols_index", "protocols_filter", "eyebrow").presence || "I'm here because…" %></span>
      <div class="chips" style="display:flex;flex-wrap:wrap;gap:14px;margin-top:24px">
        <% chips = [
             ["all",      "Show me everything"],
             ["bride",    "I have a wedding ahead"],
             ["tired",    "My skin looks tired"],
             ["hair",     "I'm losing hair"],
             ["maintain", "I want to maintain"],
             ["fresh",    "I want to start fresh"],
             ["unsure",   "I'm not sure yet"]
           ] %>
        <% chips.each do |persona, label| %>
          <button type="button"
                  class="chip<%= " is-active" if persona == "all" %>"
                  data-action="filter#select"
                  data-filter-persona-param="<%= persona %>"><%= label %></button>
        <% end %>
      </div>
    </div>

    <div class="proto-grid" style="margin-top:var(--space-block)">
      <% @protocols.each do |protocol| %>
        <div class="filter-item" data-filter-target="item" data-persona="<%= protocol.persona %>">
          <%= render "protocols/card", protocol: protocol %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ---- Closing CTA ---- %>
<section class="cta-center orn-host" data-controller="reveal">
  <%= render "shared/orn", variant: "rings", pos: "halo", size: 380 %>
  <p class="reveal" data-reveal-target="item" style="font-family:var(--serif);font-style:italic"><%= sec_text("protocols_index", "protocols_cta", "kicker").presence || "Not sure where to start?" %></p>
  <h2 class="reveal d1" data-reveal-target="item"><%= sec_text("protocols_index", "protocols_cta", "title").presence || "Begin with the" %> <span class="em"><%= sec_text("protocols_index", "protocols_cta", "title_em").presence || "NeuSkin Method™" %></span></h2>
  <p class="reveal d2" data-reveal-target="item"><%= link_to (sec_text("protocols_index", "protocols_cta", "button").presence || "Begin with the NeuSkin Method™"), neuskin_method_path, class: "btn" %></p>
</section>
