<%# One protocol card — matches design (tag chip over image, Duration / For meta row). %>
<% proto_imgs = { "neuskin-method" => "site/protocols/neuskin-method.jpg", "90-day-glow-reset" => "site/protocols/glow-reset.jpg",
                  "brides-180" => "site/protocols/bridal.jpg", "reset-crown" => "site/protocols/hair.jpg",
                  "8-week-sculpt" => "site/protocols/sculpt.jpg", "skin-insider" => "site/protocols/insider.jpg" } %>
<% img = proto_imgs[protocol.slug] || "site/protocols/skin.jpg" %>
<% for_who = protocol.who_for.to_s.split(/[.\n]/).first.to_s.strip.truncate(26, omission: "…").presence || "By assessment" %>
<%# Chip = category only (meta is "duration · category"); drop the duration part. %>
<% chip = protocol.meta.to_s.split("·").last.to_s.strip.presence || protocol.meta %>
<%= link_to protocol_path(protocol), class: "proto-card filter-item reveal", data: { reveal_target: "item", persona: protocol.persona } do %>
  <span class="proto-card-img">
    <%= image_tag img, alt: protocol.name %>
    <span class="proto-card-tag"><%= chip %></span>
  </span>
  <span class="proto-card-body">
    <h3><bdi><%= protocol.name %><% if protocol.trademark %><span class="tm">™</span><% end %></bdi></h3>
    <p class="promise"><%= protocol.promise %></p>
    <span class="proto-card-meta">
      <span class="dur"><%= protocol.duration %></span>
      <span class="for"><%= for_who %></span>
    </span>
  </span>
<% end %>
