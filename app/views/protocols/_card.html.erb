<%# One protocol card. Used on the homepage grid and the Protocols Hub. %>
<% proto_imgs = { "maysa-method" => "site/protocols/maysa-method.jpg", "90-day-glow-reset" => "site/protocols/glow-reset.jpg",
                  "brides-180" => "site/protocols/bridal.jpg", "reset-crown" => "site/protocols/hair.jpg",
                  "8-week-sculpt" => "site/protocols/sculpt.jpg", "skin-insider" => "site/protocols/insider.jpg" } %>
<% img = proto_imgs[protocol.slug] %>
<%= link_to protocol_path(protocol), class: "proto reveal#{' has-img' if img}", data: { reveal_target: "item" } do %>
  <% if img %><span class="proto-img" style="--shot-photo: url('<%= asset_path(img) %>')" aria-hidden="true"></span><% end %>
  <span class="pname" dir="<%= loc_dir %>"><%= protocol.name %><% if protocol.trademark %><span class="tm">™</span><% end %></span>
  <p class="promise"><%= protocol.promise %></p>
  <span class="meta"><%= protocol.meta %></span>
<% end %>
