<% content_for :crumb, "Workspace" %>
<% content_for :heading, "Team" %>
<% content_for :title, "Team" %>

<div style="display:flex;justify-content:space-between;align-items:center;margin:0 0 22px">
  <p style="color:var(--ns-muted);font-size:13.5px;margin:0">The Medical Team page, in display order. Lower position shows first.</p>
  <%= link_to "Add member", new_admin_team_member_path, class: "ns-btn primary" %>
</div>

<% if @members.any? %>
  <div class="ns-thead">
    <span class="r-title">Name</span>
    <span style="width:220px">Role</span>
    <span style="width:80px">Position</span>
    <span style="width:90px">Photo</span>
    <span style="width:16px"></span>
  </div>

  <ul class="ns-list">
    <% @members.each do |member| %>
      <li>
        <%= link_to edit_admin_team_member_path(member), class: "ns-row" do %>
          <span class="r-title"><%= member.name_en %></span>
          <span class="r-meta" style="width:220px"><%= member.role_en %></span>
          <span class="r-meta" style="width:80px"><%= member.position %></span>
          <span class="r-meta" style="width:90px"><%= member.photo.attached? ? "Uploaded" : "Default" %></span>
          <svg class="r-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M9 18l6-6-6-6"/></svg>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="ns-empty">No team members yet — add the first one.</div>
<% end %>
