<% content_for :crumb, "Protocols" %>
<% content_for :heading, @protocol.name_en %>
<% content_for :title, "Edit protocol" %>

<%= render "form" %>

<div style="margin-top:26px">
  <%= button_to "Delete this protocol", admin_protocol_path(@protocol), method: :delete,
