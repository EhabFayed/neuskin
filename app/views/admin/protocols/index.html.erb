<% content_for :crumb, "Workspace" %>
<% content_for :heading, "Protocols" %>
<% content_for :title, "Protocols" %>

<div style="display:flex;justify-content:space-between;align-items:center;margin:0 0 22px">
  <p style="color:var(--ns-muted);font-size:13.5px;margin:0">
    The clinic's protocols. Copy, ordering and settings are editable here; the
    structured plan data (staged timeline, per-protocol FAQ) is managed with
    the development team.
  </p>
  <%= link_to "Add protocol", new_admin_protocol_path, class: "ns-btn primary", style: "flex:none;margin-left:20px" %>
</div>

<div class="ns-thead">
  <span class="r-title">Protocol</span>
  <span style="width:170px">Duration</span>
  <span style="width:80px">Position</span>
  <span style="width:16px"></span>
</div>

<ul class="ns-list">
  <% @protocols.each do |protocol| %>
    <li>
      <%= link_to edit_admin_protocol_path(protocol), class: "ns-row" do %>
        <span class="r-title"><%= protocol.name_en %><%= "™" if protocol.trademark %></span>
        <span class="r-meta" style="width:170px"><%= protocol.duration_en %></span>
        <span class="r-meta" style="width:80px"><%= protocol.position %></span>
        <svg class="r-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M9 18l6-6-6-6"/></svg>
      <% end %>
    </li>
  <% end %>
</ul>
