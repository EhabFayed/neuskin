<%# The NeuSkin Method™ — the philosophy page (renamed from Maysa Method™,
    July 2026; internal maysa_method keys kept). %>

<%# ---- Hero (stacked: eyebrow → h2 → h1) ---- %>
<%# Atmospheric hero — the background image is the method_hero section image in
    the dashboard; the static asset is only the fallback. %>
<section class="page-hero mm-hero has-bg" data-controller="reveal"
         style="--hero-bg: url('<%= sec_image("maysa_method", "method_hero", :clinic_shot_1) %>')">
  <div class="section-inner">
    <span class="eyebrow" data-reveal="fade"><%= sec_text("maysa_method", "method_hero", "eyebrow").presence || "The Philosophy" %></span>
    <h2 class="mm-hero-sub" data-reveal="mask" data-reveal-delay="160"><span><%= sec_text("maysa_method", "method_hero", "sub").presence || "Skin is data." %></span></h2>
    <h1 class="mm-hero-main" data-reveal="mask" data-reveal-delay="320"><span><%= sec_text("maysa_method", "method_hero", "main").presence || "Read it, then treat it." %></span></h1>
  </div>
</section>

<%# ---- The principle (2-col) ---- %>
<section class="section section--surface orn-host" data-controller="reveal">
  <%= render "shared/orn", variant: "rings", pos: "tr", size: 280 %>
  <div class="section-inner split" style="align-items:start">
    <h2 data-reveal="up" style="font-size:clamp(1.6rem,2.6vw,2.4rem); color:var(--text-bright)"><%= sec_text("maysa_method", "method_principle", "title").presence || "The principle" %></h2>
    <p class="lead" data-reveal="up" data-reveal-delay="120"><%= sec_text("maysa_method", "method_principle", "lead").presence || "The NeuSkin Method™ is not a treatment. It is a way of deciding. Before anything is recommended, we read the skin, hair and body as a single connected system and let that reading — not a menu — decide what comes next." %></p>
  </div>
</section>

<%# ---- Four pillars ---- %>
<section class="section section--surface" data-controller="reveal" style="padding-top:0">
  <div class="section-inner">
    <%# Flip cards: image + title front, body copy on the back. Card images come
        from this section's gallery in the dashboard (upload 4 in order). %>
    <% pillar_defaults = ["site/protocols/skin.jpg", "site/protocols/hair.jpg", "site/space/private-suite.webp", "site/lounge.jpg"] %>
    <% pillar_texts = [["Skin", "Barrier, tone, texture and pigment — read, then restored in order."],
                       ["Hair", "Scalp health and density, assessed clinically and supported over weeks."],
                       ["Body", "Tone, contour and posture — measured, not guessed, and supported clinically."],
                       ["Lifestyle", "Sleep, sun, stress and habit — the quiet inputs that decide how the rest holds."]] %>
    <div class="cols cols-4 pillars" data-reveal="up">
      <% pillar_texts.each_with_index do |(title_default, body_default), idx| %>
        <% i = idx + 1 %>
        <% p_num   = sec_text("maysa_method", "method_pillars", "pillar_#{i}_num").presence   || "Pillar 0#{i}" %>
        <% p_title = sec_text("maysa_method", "method_pillars", "pillar_#{i}_title").presence || title_default %>
        <% p_body  = sec_text("maysa_method", "method_pillars", "pillar_#{i}_body").presence  || body_default %>
        <div class="col flipcard">
          <div class="flip-inner">
            <div class="flip-front">
              <img src="<%= sec_card_image("maysa_method", "method_pillars", i, pillar_defaults[idx]) %>" alt="" class="flip-img">
              <span class="num"><%= p_num %></span>
              <h3><%= p_title %></h3>
              <svg class="flip-cue" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-2.64-6.36"/><path d="M21 3v6h-6"/></svg>
            </div>
            <div class="flip-back">
              <span class="num"><%= p_num %></span>
              <h3><%= p_title %></h3>
              <p><%= p_body %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ---- What it is not (LIGHT contrast band, 2-col) ---- %>
<section class="section section--light" data-controller="reveal">
  <div class="section-inner split" style="align-items:start">
    <div data-reveal="up">
      <span class="eyebrow"><%= sec_text("maysa_method", "method_not", "eyebrow").presence || "What it is not" %></span>
      <h2 style="margin-top:22px; font-size:clamp(1.9rem,3.4vw,3rem)"><%= sec_text("maysa_method", "method_not", "title_1").presence || "Discipline is mostly" %> <span class="em"><%= sec_text("maysa_method", "method_not", "title_em").presence || "restraint." %></span></h2>
    </div>
    <ul class="exclude" data-reveal="up" data-reveal-delay="120">
      <li><%= sec_text("maysa_method", "method_not", "item_1").presence || "It is not a treatment, and nothing is performed during it." %></li>
      <li><%= sec_text("maysa_method", "method_not", "item_2").presence || "It is not a quick fix; good skin is sequenced over time." %></li>
      <li><%= sec_text("maysa_method", "method_not", "item_3").presence || "It is not a price list, and it is never sold from a menu." %></li>
      <li><%= sec_text("maysa_method", "method_not", "item_4").presence || "It is not for everyone — and that is entirely intentional." %></li>
    </ul>
  </div>
</section>

<%# ---- A year, in four movements — pinned horizontal scroller ---- %>
<section class="hscroll" data-controller="hscroll">
  <div class="hscroll-pin">
    <div class="hscroll-track" data-hscroll-target="track">
      <div class="hscroll-intro">
        <span class="eyebrow"><%= sec_text("maysa_method", "method_timeline", "eyebrow").presence || "The 12-month timeline" %></span>
        <h2><%= sec_text("maysa_method", "method_timeline", "title_1").presence || "A year, in" %> <span class="em"><%= sec_text("maysa_method", "method_timeline", "title_em").presence || "four movements." %></span></h2>
        <p><%= sec_text("maysa_method", "method_timeline", "intro_body").presence || "The NeuSkin Method™ unfolds over four quarters — measured, reviewed, adjusted. Scroll through the year." %></p>
        <div class="cue"><%= sec_text("maysa_method", "method_timeline", "cue").presence || "Scroll →" %></div>
      </div>
      <%# Quarter panels flip: image + quarter front, body on the back. Images
          come from this section's gallery in the dashboard (upload 4 in order). %>
      <% panel_defaults = ["site/space/device-room.webp", "site/space/treatment.webp", "site/space/clinic-4.webp", "site/space/clinic-1.webp"] %>
      <% panel_texts = [["Diagnose", "Baseline captured, the plan written. The slow, invisible work begins."],
                        ["Restore",  "Targeted correction across the four pillars, reviewed against baseline."],
                        ["Build",    "Results compounded; the plan adjusted to how your skin responded."],
                        ["Maintain", "A maintenance rhythm set, and a record you keep for the years ahead."]] %>
      <% panel_texts.each_with_index do |(title_default, body_default), idx| %>
        <% i = idx + 1 %>
        <% q_label = sec_text("maysa_method", "method_timeline", "panel_#{i}_q").presence     || "Q#{i}" %>
        <% q_title = sec_text("maysa_method", "method_timeline", "panel_#{i}_title").presence || title_default %>
        <% q_body  = sec_text("maysa_method", "method_timeline", "panel_#{i}_body").presence  || body_default %>
        <div class="hpanel flipcard">
          <div class="flip-inner">
            <div class="flip-front">
              <img src="<%= sec_card_image("maysa_method", "method_timeline", i, panel_defaults[idx]) %>" alt="" class="flip-img">
              <h4 class="q"><%= q_label %></h4>
              <h3><%= q_title %></h3>
              <svg class="flip-cue" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-2.64-6.36"/><path d="M21 3v6h-6"/></svg>
            </div>
            <div class="flip-back">
              <h4 class="q"><%= q_label %></h4>
              <h3><%= q_title %></h3>
              <p><%= q_body %></p>
            </div>
          </div>
        </div>
      <% end %>
      <div class="hshot-outro">
        <blockquote><%= sec_text("maysa_method", "method_timeline", "quote").presence || "“Skin is data. Read it across a year, and it stops surprising you.”" %></blockquote>
        <%= link_to (sec_text("maysa_method", "method_timeline", "cta_label").presence || "Request the Assessment"), inquire_path(codeword: "METHOD"), class: "btn", style: "align-self:flex-start" %>
      </div>
    </div>
  </div>
</section>

<%# ---- Closing CTA ---- %>
<section class="cta-center orn-host" data-controller="reveal">
  <%= render "shared/orn", variant: "rings", pos: "halo", size: 380 %>
  <h2 class="reveal" data-reveal-target="item"><%= sec_text("maysa_method", "method_cta", "title_1").presence || "Begin with the" %> <span class="em"><%= sec_text("maysa_method", "method_cta", "title_em").presence || "NeuSkin Method™." %></span></h2>
  <p class="reveal d1" data-reveal-target="item"><%= sec_text("maysa_method", "method_cta", "body").presence || "One reading, one written plan, reviewed every quarter. It begins with a private inquiry." %></p>
  <p class="reveal d2" data-reveal-target="item"><%= link_to (sec_text("maysa_method", "method_cta", "cta_label").presence || "Request the Assessment"), inquire_path(codeword: "METHOD", persona: "unsure"), class: "btn" %></p>
</section>
