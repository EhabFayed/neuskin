<%# The Medical Team (§04) — the credibility layer. %>

<section class="section team-hero" data-controller="reveal">
  <div class="wrap narrow" style="text-align:center">
    <span class="label reveal" data-reveal-target="item"><%= t("team.eyebrow") %></span>
    <h1 class="team-title reveal" data-reveal-target="item">
      <span class="ar" dir="rtl"><%= t("team.title_ar") %></span>
      <span class="en"><%= t("team.title_en") %></span>
    </h1>
    <p class="team-intro reveal" data-reveal-target="item">
      <span class="ar" dir="rtl"><%= t("team.intro_ar") %></span>
      <span class="en"><%= t("team.intro_en") %></span>
    </p>
  </div>
</section>

<section class="section team-body" data-controller="reveal">
  <div class="wrap">
    <div class="team-grid">
      <% t("team.members").each_with_index do |member, i| %>
        <article class="team-member reveal" data-reveal-target="item">
          <div class="team-portrait team-portrait--<%= i % 4 %>" role="img"
               aria-label="<%= "#{member[:name_en]}, #{member[:title_en]}" %>"></div>
          <div class="team-info">
            <h2 class="team-name">
              <span class="ar" dir="rtl"><%= member[:name_ar] %></span>
              <span class="en"><%= member[:name_en] %></span>
            </h2>
            <p class="team-role">
              <span class="ar" dir="rtl"><%= member[:title_ar] %></span>
              <span class="en"><%= member[:title_en] %></span>
            </p>
            <p class="team-certs"><%= member[:certs] %></p>
            <p class="team-focus">
              <span class="team-focus-label"><%= t("team.focus_label") %></span>
              <%= member[:focus] %>
            </p>
            <p class="team-bio"><%= member[:bio] %></p>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</section>

<%# CTA %>
<section class="section section--night invite">
  <div class="wrap">
    <span class="label"><%= t("team.cta_label") %></span>
    <p class="line-ar" dir="rtl"><%= t("team.cta_ar") %></p>
    <p class="line-en"><%= t("team.cta_en") %></p>
    <%= link_to t("cta.private_inquiry"), inquire_path, class: "cta" %>
  </div>
</section>
