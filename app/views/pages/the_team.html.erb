<%# The Medical Team — dynamic (TeamMember records; top_brand leadership port). %>

<%# ---- Hero ---- %>
<%# Atmospheric hero — the background image is the team_hero section image in
    the dashboard; the static asset is only the fallback. %>
<section class="page-hero has-bg" data-controller="reveal"
         style="--hero-bg: url('<%= sec_image("the_team", "team_hero", :clinic_hero) %>')">
  <div class="section-inner">
  <span class="eyebrow center reveal" data-reveal-target="item"><%= sec_text("the_team", "team_hero", "eyebrow").presence || "The Medical Team" %></span>
  <h1>
    <span data-reveal="mask" data-reveal-delay="120"><span><%= sec_text("the_team", "team_hero", "title_1").presence || "The people behind" %></span></span>
    <span class="em" data-reveal="mask" data-reveal-delay="240"><span><%= sec_text("the_team", "team_hero", "title_em").presence || "the plan." %></span></span>
  </h1>
  <p class="lead reveal d2" data-reveal-target="item">
    <%= sec_text("the_team", "team_hero", "lead").presence || "A small, credentialed team — led by our medical director, organised by seniority, and chosen for restraint as much as skill." %>
  </p>
  </div>
</section>

<%# ---- Team grid ---- %>
<section class="section section--surface" data-controller="reveal">
  <div class="section-inner">
    <div class="team-grid reveal d1" data-reveal-target="item">
      <% fallback_photos = %i[portrait_natural consult doctor_coat beauty_eyes] %>
      <% @members.each_with_index do |member, i| %>
        <div class="member">
          <div class="member-photo">
            <% if member.photo.attached? %>
              <%= image_tag member.photo, alt: member.name %>
            <% else %>
              <%= ns_image_tag fallback_photos[i % fallback_photos.size], alt: member.name %>
            <% end %>
          </div>
          <h3><%= member.name %></h3>
          <div class="role"><%= member.role %></div>
          <div class="cred"><%= member.cred %></div>
          <% if member.focus.present? %>
            <div class="focus"><%= t("team.focus") %> · <%= member.focus %></div>
          <% end %>
          <p class="bio"><%= member.bio %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
