<%# FAQ (design §isFaq) — search + accordion, grouped questions. %>

<%
  faq_groups = [
    { title: "Before you come in", qs: [
      { q: "Do you publish a price list?",
        a: "No. Care is arranged by consultation, never sold from a menu. We discuss investment privately once we understand what your skin actually needs." },
      { q: "How do I start?",
        a: "Send a private inquiry — on WhatsApp or through the form. Dr. Maysa or our patient relations lead reviews every message personally." },
      { q: "Is the first visit a treatment?",
        a: "No. The first appointment is a doctor-led diagnostic assessment. Nothing is performed; we read your skin and write a plan." }
    ] },
    { title: "How care works", qs: [
      { q: "Why a twelve-month plan?",
        a: "Good skin is sequenced over time, not forced in a single session. We plan across quarters and review the results every three months." },
      { q: "Will I see Dr. Maysa herself?",
        a: "Your initial assessment is conducted personally by Dr. Maysa. Ongoing care may involve the wider medical team, always under her direction." },
      { q: "What if a treatment isn't right for me?",
        a: "Then we say so. Turning something down is part of the practice — we would rather keep your trust than sell you a session." }
    ] },
    { title: "Privacy & practicalities", qs: [
      { q: "How private is my information?",
        a: "Your inquiry is seen only by our patient relations lead and Dr. Maysa. We are PDPL compliant and store data securely." },
      { q: "Do you photograph patients?",
        a: "Only with separate, specific, written consent. Consent is never assumed and can be withdrawn at any time." },
      { q: "Where are you, and when are you open?",
        a: "Al Malqa, Riyadh. Saturday to Thursday, 10:00–22:00. Friday closed. The exact address is shared when we schedule." }
    ] }
  ]
%>

<section class="page-hero" data-controller="reveal faqsearch">
  <span class="eyebrow reveal" data-reveal-target="item">Frequently Asked</span>
  <h1>
    <span data-reveal="mask" data-reveal-delay="120"><span>The questions</span></span>
    <span class="em" data-reveal="mask" data-reveal-delay="240"><span>before the question.</span></span>
  </h1>
  <input class="faq-search reveal d2" data-reveal-target="item"
         data-faqsearch-target="query"
         data-action="input->faqsearch#filter"
         placeholder="Search the questions">

  <div class="section-inner" style="padding-block-start:clamp(40px,5vw,64px)">
    <% faq_groups.each do |group| %>
      <div class="faq-group" data-faqsearch-target="group">
        <h2><%= group[:title] %></h2>
        <% group[:qs].each do |item| %>
          <details class="faq" data-faqsearch-target="item"
                   data-search="<%= "#{item[:q]} #{item[:a]}".downcase %>">
            <summary><%= item[:q] %> <span class="sign">+</span></summary>
            <div class="faq-a"><%= item[:a] %></div>
          </details>
        <% end %>
      </div>
    <% end %>
    <p class="faq-empty" data-faqsearch-target="empty" hidden>No questions match.</p>
  </div>
</section>
