<%# FAQ (design §isFaq) — search + accordion, dynamic (Faq records). %>

<div class="faq-page" data-controller="reveal faqsearch">
  <%# FAQ hero — 1:1 port of design §isFaq %>
  <section class="fq-hero orn-host">
    <%= render "shared/orn", variant: "rings", pos: "tr", size: 460 %>
    <div class="fq-eyebrow reveal" data-reveal-target="item">
      <span class="rule"></span>
      <span class="lbl"><%= sec_text("faq", "faq_hero", "eyebrow").presence || "Frequently Asked" %></span>
    </div>
    <h1 class="fq-title" data-reveal="up"><%= sec_text("faq", "faq_hero", "title_1").presence || "The questions" %><br><span class="em"><%= sec_text("faq", "faq_hero", "title_em").presence || "before the question." %></span></h1>
    <div class="fq-search" data-reveal="up" data-reveal-delay="140">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8a7c79" stroke-width="1.5"><circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4-4"></path></svg>
      <input placeholder="<%= sec_text("faq", "faq_hero", "search_placeholder").presence || "Search the questions" %>"
             data-faqsearch-target="query"
             data-action="input->faqsearch#filter">
    </div>
  </section>

  <%# FAQ groups — sticky title left, accordion right %>
  <section class="fq-groups">
    <% @faq_groups.each do |category, faqs| %>
      <div class="fq-group" data-reveal="up" data-faqsearch-target="group">
        <h2 class="fq-group-title"><%= t("faq.groups.#{category}") %></h2>
        <div class="fq-list">
          <% faqs.each do |faq| %>
            <details class="fq-item" data-faqsearch-target="item"
                     data-search="<%= "#{faq.question} #{faq.answer}".downcase %>">
              <summary><span class="fq-q"><%= faq.question %></span><span class="fq-sign">+</span></summary>
              <p class="fq-a"><%= faq.answer %></p>
            </details>
          <% end %>
        </div>
      </div>
    <% end %>
    <p class="faq-empty" data-faqsearch-target="empty" hidden><%= sec_text("faq", "faq_hero", "empty_state").presence || "No questions match." %></p>
  </section>
</div>
