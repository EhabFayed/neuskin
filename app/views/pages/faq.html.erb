<%# FAQ (§14) — 20 questions, 4 groups of 5, search + accordion. %>

<section class="section faq-hero" data-controller="reveal">
  <div class="wrap narrow" style="text-align:center">
    <span class="label reveal" data-reveal-target="item"><%= t("faq.eyebrow") %></span>
    <h1 class="faq-title reveal" data-reveal-target="item">
      <span class="ar" dir="rtl"><%= t("faq.title_ar") %></span>
      <span class="en"><%= t("faq.title_en") %></span>
    </h1>
  </div>
</section>

<section class="section faq-body" data-controller="faqsearch">
  <div class="wrap narrow">
    <div class="faq-search">
      <input type="search" data-faqsearch-target="query" data-action="input->faqsearch#filter"
             placeholder="<%= t('faq.search_ph') %>" aria-label="<%= t('faq.search_ph') %>">
    </div>

    <% %w[clinic treatments protocols privacy].each do |group| %>
      <div class="faq-group" data-faqsearch-target="group">
        <h2 class="faq-group-title" data-faqsearch-target="groupTitle">
          <span class="ar" dir="rtl"><%= t("faq.groups.#{group}.title_ar") %></span>
          <span class="en"><%= t("faq.groups.#{group}.title_en") %></span>
        </h2>

        <% t("faq.groups.#{group}.items").each do |item| %>
          <details class="faq" data-faqsearch-target="item"
                   data-search="<%= "#{item[:q_ar]} #{item[:q_en]} #{item[:a_ar]} #{item[:a_en]}".downcase %>">
            <summary>
              <span class="ar" dir="rtl"><%= item[:q_ar] %></span>
              <span class="en"><%= item[:q_en] %></span>
            </summary>
            <div class="faq-a">
              <p class="ar" dir="rtl"><%= item[:a_ar] %></p>
              <p class="en"><%= item[:a_en] %></p>
              <p class="faq-sign" dir="rtl">— د. ميساء</p>
            </div>
          </details>
        <% end %>
      </div>
    <% end %>

    <p class="faq-empty" data-faqsearch-target="empty" hidden><%= t("faq.no_results") %></p>
  </div>
</section>

<%# CTA — a question we didn't answer? %>
<section class="section section--night invite">
  <div class="wrap">
    <span class="label"><%= t("faq.cta_label") %></span>
    <p class="line-ar" dir="rtl"><%= t("faq.cta_ar") %></p>
    <p class="line-en"><%= t("faq.cta_en") %></p>
    <%= link_to t("cta.private_inquiry"), inquire_path, class: "cta" %>
  </div>
</section>
