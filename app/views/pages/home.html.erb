<%# Homepage — 6 sections per the Website Architecture. Bilingual side-by-side. %>

<section class="hero" data-controller="reveal">
  <span class="seam"></span>
  <h1 class="<%= ar? ? "hero-ar" : "hero-en" %> reveal d2" data-reveal-target="item" dir="<%= loc_dir %>"><%= t("home.hero_h1").html_safe %></h1>
  <p class="hero-sub reveal d3" data-reveal-target="item" dir="<%= loc_dir %>">
    <%= t("home.hero_sub") %>
  </p>
  <div class="cta-row reveal d4" data-reveal-target="item">
    <%= link_to t("cta.assessment"), inquire_path(codeword: "METHOD", persona: "unsure"), class: "cta" %>
    <%= link_to t("cta.whatsapp"), whatsapp_url, class: "micro-cta", target: "_blank", rel: "noopener" %>
  </div>
  <span class="scroll-cue">Scroll</span>
</section>

<%# Quiet credibility strip — copy-woven trust, never a badge wall (Lutétia/Hortman). %>
<section class="cred-strip" data-controller="reveal">
  <div class="wrap">
    <ul class="cred-strip-items reveal" data-reveal-target="item">
      <% t("home.credibility").each do |item| %>
        <li dir="<%= loc_dir %>"><%= loc(ar: item[:ar], en: item[:en]) %></li>
      <% end %>
    </ul>
  </div>
</section>

<%# Section 2 — The Promise (three pillars) %>
<section class="section section--deep" id="clinic" data-controller="reveal">
  <div class="wrap">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="label"><%= t("home.promise_label") %></span>
      <h2 dir="<%= loc_dir %>"><%= t("home.promise_title") %></h2>
    </div>
    <div class="pillars">
      <%= render "pages/pillar", extra: "from-left", num: "01", ar_title: "بقيادة الطبيبة", en_title: "Doctor-led",
            ar_body: "كل خطة تضعها د. ميساء بنفسها — لا قائمة خدمات.",
            en_body: "Every plan is built by Dr. Maysa — not chosen from a menu." %>
      <%= render "pages/pillar", extra: "from-bottom", num: "02", ar_title: "بسريّة تامة", en_title: "Discreet",
            ar_body: "استشارة خاصة. علاج خاص. نتائج خاصة.",
            en_body: "Private consultation. Private treatment. Private results." %>
      <%= render "pages/pillar", extra: "from-right", num: "03", ar_title: "مقاسة بدقّة", en_title: "Measured",
            ar_body: "نتائج موثّقة كل ثلاثة أشهر. بلا تخمين، بلا ضجيج.",
            en_body: "Outcomes documented quarterly. No guesswork, no drama." %>
    </div>
  </div>
</section>

<%# Section 3 — Meet Dr. Maysa (preview) %>
<section class="section" id="doctor" data-controller="reveal">
  <div class="wrap">
    <div class="doctor">
      <div class="portrait has-photo reveal-img" data-reveal-target="item" style="--portrait-photo: url('<%= asset_path('site/people/maysa.jpg') %>')" role="img" aria-label="Editorial portrait of Dr. Maysa"></div>
      <div class="doctor-copy reveal" data-reveal-target="item">
        <span class="label"><%= t("home.founder_label") %></span>
        <blockquote dir="<%= loc_dir %>">
          <%= t("home.founder_quote") %>
        </blockquote>
        <p dir="<%= loc_dir %>"><%= t("home.founder_body") %></p>
        <p class="signed" dir="rtl">— د. ميساء</p>
        <%= link_to t("home.founder_link"), dr_maysa_path, class: "textlink" %>
      </div>
    </div>
  </div>
</section>

<%# Concern-led discovery (dual-axis, Lutétia "vos besoins"). Routes into the hub by persona. %>
<section class="section concern-strip" data-controller="reveal">
  <div class="wrap">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="label"><%= t("home.concern.label") %></span>
      <h2 dir="<%= loc_dir %>"><%= loc(ar: t("home.concern.title_ar"), en: t("home.concern.title_en")) %></h2>
    </div>
    <div class="concern-grid">
      <% t("home.concern.items").each do |c| %>
        <%= link_to protocols_path(persona: c[:persona]), class: "concern reveal", data: { reveal_target: "item" }, dir: loc_dir do %>
          <%= loc(ar: c[:ar], en: c[:en]) %>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<%# Section 4 — The six protocols %>
<section class="section section--deep" id="protocols" data-controller="reveal">
  <div class="wrap">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="label"><%= t("protocols.eyebrow_tagline") %></span>
      <h2 dir="<%= loc_dir %>"><%= t("home.protocols_title") %></h2>
    </div>
    <div class="protocols">
      <%= render partial: "protocols/card", collection: Protocol.all, as: :protocol %>
    </div>
  </div>
</section>

<%# Section 5 — Patient voice %>
<section class="section" id="voices" data-controller="reveal">
  <div class="wrap">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="label"><%= t("home.voice_label") %></span>
      <h2 dir="<%= loc_dir %>"><%= t("home.voice_title") %></h2>
    </div>
    <div class="voices">
      <% t("home.voices").each do |v| %>
        <div class="voice reveal" data-reveal-target="item">
          <span class="mark">”</span>
          <p class="q" dir="<%= loc_dir %>"><%= v[:q] %></p>
          <p class="by">— <%= v[:by] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# Section 6 — The invitation (closing CTA) %>
<section class="section section--night invite has-texture" id="inquire"
         style="--band-photo: url('<%= asset_path('site/desert-atmosphere.jpg') %>')">
  <div class="wrap">
    <span class="label"><%= t("home.invite_label") %></span>
    <p class="<%= ar? ? "line-ar" : "line-en" %>" dir="<%= loc_dir %>"><%= t("home.invite_line") %></p>
    <%= link_to t("cta.private_inquiry"), inquire_path, class: "cta" %>
    <p class="signed" dir="rtl">— د. ميساء</p>
  </div>
</section>
