<%# Homepage — 6 sections per the Website Architecture. Bilingual side-by-side. %>

<section class="hero" data-controller="reveal">
  <span class="seam"></span>
  <span class="label reveal d1" data-reveal-target="item">Arabic-first · Doctor-led · By consultation</span>
  <h1 class="hero-ar reveal d2" data-reveal-target="item" dir="rtl">بشرة تليق بجمالك<br>وثقة تليق بإطلالتك</h1>
  <p class="hero-en reveal d3" data-reveal-target="item">Skin, measured. Confidence, quiet. Here.</p>
  <p class="hero-sub reveal d3" data-reveal-target="item">
    <span class="ar" dir="rtl">عيادة الذكاء الجلدي بقيادة الطبيبة، للنساء في الرياض.</span>
    The doctor-led skin intelligence clinic for women in Riyadh.
  </p>
  <div class="cta-row reveal d4" data-reveal-target="item">
    <%= link_to t("cta.assessment"), root_path(anchor: "inquire"), class: "cta" %>
    <a class="micro-cta" href="#"><%= t("cta.whatsapp") %></a>
  </div>
  <span class="scroll-cue">Scroll</span>
</section>

<%# Section 2 — The Promise (three pillars) %>
<section class="section section--deep" id="clinic" data-controller="reveal">
  <div class="wrap">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="label">The Promise · وعدنا</span>
      <h2>Three things we hold to.</h2>
    </div>
    <div class="pillars">
      <%= render "pages/pillar", num: "01", ar_title: "بقيادة الطبيبة", en_title: "Doctor-led",
            ar_body: "كل خطة تضعها د. ميساء بنفسها — لا قائمة خدمات.",
            en_body: "Every plan is built by Dr. Maysa — not chosen from a menu." %>
      <%= render "pages/pillar", num: "02", ar_title: "بسريّة تامة", en_title: "Discreet",
            ar_body: "استشارة خاصة. علاج خاص. نتائج خاصة.",
            en_body: "Private consultation. Private treatment. Private results." %>
      <%= render "pages/pillar", num: "03", ar_title: "مقاسة بدقّة", en_title: "Measured",
            ar_body: "نتائج موثّقة كل ثلاثة أشهر. بلا تخمين، بلا ضجيج.",
            en_body: "Outcomes documented quarterly. No guesswork, no drama." %>
    </div>
  </div>
</section>

<%# Section 3 — Meet Dr. Maysa (preview) %>
<section class="section" id="doctor" data-controller="reveal">
  <div class="wrap">
    <div class="doctor">
      <div class="portrait reveal" data-reveal-target="item" role="img" aria-label="Editorial portrait of Dr. Maysa"></div>
      <div class="doctor-copy reveal" data-reveal-target="item">
        <span class="label">The Founder · المؤسِّسة</span>
        <blockquote>
          <span class="ar" dir="rtl">«البشرة بيانات. اقرأيها أولًا، ثم عالجيها.»</span>
          “Skin is data. Read it first — then treat it.”
        </blockquote>
        <p>I founded NeuSkin because I was tired of menus. A face is not a list of services. Before I treat anything, I map it — skin, hair, body, lifestyle — and I write you a plan you keep. That plan is the work. Everything after it is just patience.</p>
        <p class="signed" dir="rtl">— د. ميساء</p>
        <%= link_to "Read her philosophy · اقرئي فلسفتها", "#", class: "textlink" %>
      </div>
    </div>
  </div>
</section>

<%# Section 4 — The six protocols %>
<section class="section section--deep" id="protocols" data-controller="reveal">
  <div class="wrap">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="label">Six named protocols · One philosophy · No menu pricing</span>
      <h2><span class="ar" dir="rtl">البروتوكولات الستة</span>We work in protocols, not à-la-carte.</h2>
    </div>
    <div class="protocols">
      <% protocols.each do |p| %>
        <%= render "pages/protocol_card", protocol: p %>
      <% end %>
    </div>
  </div>
</section>

<%# Section 5 — Patient voice %>
<section class="section" id="voices" data-controller="reveal">
  <div class="wrap">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="label">Patient voice · بأصواتهنّ</span>
      <h2>Quietly, in their own words.</h2>
    </div>
    <div class="voices">
      <div class="voice reveal" data-reveal-target="item">
        <span class="mark">”</span>
        <p class="q ar" dir="rtl">«لأول مرة شعرت أن أحدًا يخطّط لبشرتي، لا يبيع لي.»</p>
        <p class="q">For the first time, someone was planning for my skin — not selling to me.</p>
        <p class="by">— M.A. · Bride's 180 · 2025</p>
      </div>
      <div class="voice reveal" data-reveal-target="item">
        <span class="mark">”</span>
        <p class="q ar" dir="rtl">«قالت لي د. ميساء "لا" أكثر مما قالت "نعم". وثقت بها أكثر.»</p>
        <p class="q">Dr. Maysa told me “no” more than she told me “yes.” I trusted her more for it.</p>
        <p class="by">— R.K. · Maysa Method™ · 2025</p>
      </div>
      <div class="voice reveal" data-reveal-target="item">
        <span class="mark">”</span>
        <p class="q ar" dir="rtl">«بعد الولادة استعدت شعري بهدوء، دون وعود كبيرة.»</p>
        <p class="q">After my pregnancy I got my hair back — quietly, with no big promises.</p>
        <p class="by">— N.S. · Reset Crown · 2024</p>
      </div>
    </div>
  </div>
</section>

<%# Section 6 — The invitation (closing CTA) %>
<section class="section section--night invite" id="inquire">
  <div class="wrap">
    <span class="label">The invitation · الدعوة</span>
    <p class="line-ar" dir="rtl">ابدئي بمحادثة هادئة.</p>
    <p class="line-en">Begin a quiet conversation.</p>
    <%= link_to t("cta.private_inquiry"), "#", class: "cta" %>
    <p class="signed" dir="rtl">— د. ميساء</p>
  </div>
</section>
