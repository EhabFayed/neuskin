<%# Homepage — NeuSkin Clinic (standalone) design port. English / LTR. %>

<%# ---- Hero (full-bleed media, centered overlay copy — Figma landing) ---- %>
<section class="hero" data-controller="reveal">
  <div class="hero-media">
    <%# Content team (July 2026): hero plays the clinic video full-bleed behind the copy. %>
    <%= video_tag "/videos/neuskin-web-data.mp4",
          class: "hero-media-video",
          autoplay: true, muted: true, loop: true, playsinline: true,
          preload: "auto" %>
  </div>
  <div class="hero-copy">
    <span class="eyebrow no-rule" data-reveal="fade"><%= sec_text("home", "home_hero", "eyebrow").presence || "Doctor-led · Riyadh" %></span>
    <h1>
      <% hero_lines = [sec_text("home", "home_hero", "headline_1").presence || "Medical Precision.",
                       sec_text("home", "home_hero", "headline_2").presence || "Aesthetic Grace.",
                       sec_text("home", "home_hero", "headline_3").presence].compact %>
      <% hero_lines.each_with_index do |line, i| %>
        <span class="ln" data-reveal="mask" data-reveal-delay="<%= 150 + i * 130 %>"><span><%= line %></span></span>
      <% end %>
    </h1>
    <p class="hero-sub" data-reveal="up" data-reveal-delay="520">
      <%= sec_text("home", "home_hero", "sub").presence || "Riyadh's doctor-led skin intelligence clinic. Where your aesthetic journey is guided by expert care, subtle results, and absolute privacy." %>
    </p>
    <div class="hero-cta" data-reveal="up" data-reveal-delay="640">
      <%= link_to "Request an assessment", inquire_path(codeword: "METHOD", persona: "unsure"), class: "btn", data: { controller: "magnetic" } %>
      <a class="btn btn--ghost" href="<%= whatsapp_url %>" target="_blank" rel="noopener">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="#6fb98a" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
        Speak privately on WhatsApp
      </a>
    </div>
  </div>
</section>

<%# ---- Three principles ---- %>
<section class="section orn-host" data-controller="reveal">
  <%= render "shared/orn", variant: "rings", pos: "tr", float: true %>
  <div class="section-inner">
    <div class="sec-head center reveal" data-reveal-target="item">
      <span class="eyebrow center"><%= sec_text("home", "home_principles", "eyebrow").presence || "The Promise" %></span>
      <h2><%= sec_text("home", "home_principles", "title").presence || "Three commitments, quietly kept." %></h2>
    </div>
    <%# Slide carousel (Seline-style): one principle per full-width slide —
        image + number/title/body glide sideways, autoplay with arrows/dots.
        Texts and per-card images stay dashboard-editable as before. %>
    <% pillar_defaults = ["site/space/consultation.jpg", "site/space/entrance.webp", "site/space/device-room.webp"] %>
    <% pillars = [[1, "01 — Principle", "Doctor-led",  "Every plan is designed by our medical team — never assembled from a treatment menu. You meet a clinician first, and a recommendation second."],
                  [2, "02 — Principle", "Discreet",    "Private consultation. Private treatment. Private results. A quiet room, a closed door, and nothing that leaves it."],
                  [3, "03 — Principle", "Measured",    "Outcomes documented quarterly. No guesswork, no drama — only what the skin shows, recorded and reviewed."]] %>
    <div class="ns-expand reveal d1" data-reveal-target="item">
      <% pillars.each do |i, num_default, title_default, body_default| %>
        <% p_num   = sec_text("home", "home_principles", "p#{i}_num").presence   || num_default %>
        <% p_title = sec_text("home", "home_principles", "p#{i}_title").presence || title_default %>
        <% p_body  = sec_text("home", "home_principles", "p#{i}_body").presence  || body_default %>
        <div class="ns-panel">
          <img src="<%= sec_card_image("home", "home_principles", i, pillar_defaults[i - 1]) %>" alt="">
          <div class="ns-panel-copy">
            <span class="num"><%= p_num %></span>
            <h3><%= p_title %></h3>
            <p><%= p_body %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ---- Meet the founder (light contrast band) ---- %>
<section class="section section--light orn-host" data-controller="reveal">
  <%= render "shared/orn", variant: "petal", pos: "br", float: true %>
  <div class="section-inner split media-left">
    <div class="split-media reveal" data-reveal-target="item">
      <%= sec_image_tag("home", "home_founder", :lounge, alt: "Inside the NeuSkin clinic", class: "breathe") %>
    </div>
    <div class="split-text reveal d1" data-reveal-target="item">
      <span class="eyebrow"><%= sec_text("home", "home_founder", "eyebrow").presence || "Meet the founder" %></span>
      <div class="body-copy">
        <p><%= sec_text("home", "home_founder", "body_1").presence || "I opened NeuSkin because I was tired of watching women sold ten treatments to fill a calendar. Skin is data — it can be read, and once read, it can be treated honestly." %></p>
        <p><%= sec_text("home", "home_founder", "body_2").presence || "Every patient here is met by one doctor, who builds one plan and reviews it every quarter. Nothing is rushed, and nothing is sold that isn't needed." %></p>
      </div>
      <p class="sign"><%= sec_text("home", "home_founder", "sign") %></p>
      <%# "Read her philosophy" link hidden with the Dr. Maysa page (July 2026). %>
      <% if false %>
        <p style="margin-top:20px"><%= link_to (sec_text("home", "home_founder", "link").presence || "Read her philosophy →"), dr_maysa_path, class: "arrowlink" %></p>
      <% end %>
    </div>
  </div>
</section>

<%# ---- Marquee word band — the brand vocabulary gliding between sections ---- %>
<%= render "shared/marquee", words: ["Doctor-led", "Discreet", "Measured", "Skin intelligence", "Protocol-led", "Riyadh"] %>

<%# ---- Six protocols — row list + sticky swapping image (design §isHome) ---- %>
<% proto_imgs = { "neuskin-method" => "site/protocols/neuskin-method.jpg", "90-day-glow-reset" => "site/protocols/glow-reset.jpg",
                  "brides-180" => "site/protocols/bridal.jpg", "reset-crown" => "site/protocols/hair.jpg",
                  "8-week-sculpt" => "site/protocols/sculpt.jpg", "skin-insider" => "site/protocols/insider.jpg" } %>
<% protocols = Protocol.all.to_a %>
<section class="section section--surface" data-controller="reveal">
  <div class="section-inner">
    <div class="sec-head-row" data-reveal="up">
      <div class="sec-head" style="margin:0">
        <span class="eyebrow"><%= sec_text("home", "home_protocols", "eyebrow").presence || "The Six Protocols" %></span>
        <h2 style="margin-top:22px"><%= sec_text("home", "home_protocols", "title").presence || "Six named protocols." %> <span class="em"><%= sec_text("home", "home_protocols", "title_em").presence || "One philosophy. Zero menu pricing." %></span></h2>
      </div>
      <%= link_to (sec_text("home", "home_protocols", "link").presence || "View all protocols →"), protocols_path, class: "arrowlink" %>
    </div>

    <div class="proto-index" data-controller="protoindex" data-reveal="up" data-reveal-delay="120">
      <div class="proto-list">
        <% protocols.each_with_index do |p, i| %>
          <%= link_to protocol_path(p),
                class: "proto-row",
                data: { protoindex_target: "row", index: i,
                        action: "mouseenter->protoindex#show focus->protoindex#show",
                        tag: p.meta, promise: p.promise, href: protocol_path(p) } do %>
            <span class="ix"><%= format("%02d", i + 1) %></span>
            <h3><bdi><%= p.name %><% if p.trademark %><span class="tm">™</span><% end %></bdi></h3>
            <span class="dur"><%= p.duration %></span>
          <% end %>
        <% end %>
      </div>

      <div class="proto-stage">
        <% protocols.each_with_index do |p, i| %>
          <%= image_tag (proto_imgs[p.slug] || "site/protocols/skin.jpg"),
                class: "proto-stage-img#{' is-shown' if i.zero?}",
                alt: p.name, data: { protoindex_target: "img", index: i } %>
        <% end %>
        <div class="proto-stage-cap">
          <div class="cap-tag" data-protoindex-target="tag"><%= protocols.first&.meta %></div>
          <p class="cap-promise" data-protoindex-target="promise"><%= protocols.first&.promise %></p>
          <a class="cap-cta" data-protoindex-target="cta" href="<%= protocols.first ? protocol_path(protocols.first) : protocols_path %>">Explore this protocol →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ---- Inside the clinic — pinned horizontal scroll (design data-hscroll) ---- %>
<%# Scroll down through this tall section and the gallery tracks sideways. %>
<section class="hscroll" data-controller="hscroll">
  <div class="hscroll-pin">
    <div class="hscroll-track" data-hscroll-target="track">
      <div class="hscroll-intro">
        <span class="eyebrow"><%= sec_text("home", "home_clinic", "eyebrow").presence || "Inside NeuSkin" %></span>
        <h2><%= sec_text("home", "home_clinic", "title").presence || "The space," %> <span class="em"><%= sec_text("home", "home_clinic", "title_em").presence || "in passing." %></span></h2>
        <p><%= sec_text("home", "home_clinic", "lead").presence || "A private clinic in Al Malqa — designed for quiet. Scroll on, and move through it." %></p>
        <div class="cue"><%= sec_text("home", "home_clinic", "cue").presence || "Scroll →" %></div>
      </div>
      <% home_clinic_imgs = sec_gallery_urls("home", "home_clinic", [:treatment_room, :lounge, :device_table, :diptyque, :interior_ext]) %>
      <figure class="hshot"><%= image_tag home_clinic_imgs[0], alt: "Treatment room" %><figcaption><%= sec_text("home", "home_clinic", "cap_1").presence || "01 · Treatment room" %></figcaption></figure>
      <figure class="hshot narrow"><%= image_tag home_clinic_imgs[1], alt: "The lounge" %><figcaption><%= sec_text("home", "home_clinic", "cap_2").presence || "02 · The lounge" %></figcaption></figure>
      <figure class="hshot"><%= image_tag home_clinic_imgs[2], alt: "Device room" %><figcaption><%= sec_text("home", "home_clinic", "cap_3").presence || "03 · Device room" %></figcaption></figure>
      <figure class="hshot narrow"><%= image_tag home_clinic_imgs[3], alt: "In the detail" %><figcaption><%= sec_text("home", "home_clinic", "cap_4").presence || "04 · In the detail" %></figcaption></figure>
      <figure class="hshot"><%= image_tag home_clinic_imgs[4], alt: "The entrance" %><figcaption><%= sec_text("home", "home_clinic", "cap_5").presence || "05 · The entrance" %></figcaption></figure>
      <div class="hshot-outro">
        <blockquote><%= sec_text("home", "home_clinic", "quote").presence || "“A clinic should be measured by what it refuses to do.”" %></blockquote>
        <%= link_to (sec_text("home", "home_clinic", "outro_link").presence || "Tour the clinic →"), the_clinic_path, class: "arrowlink" %>
      </div>
    </div>
  </div>
</section>

<%# ---- Testimonials (light contrast band) ----
     Hidden per the content team (July 2026): these services are not live yet;
     the section returns once real, consented patient reviews are available.
     The home_quotes CMS section is kept so no copy is lost. %>
<% if false %>
<section class="section section--light" data-controller="reveal">
  <div class="section-inner">
    <div class="sec-head center reveal" data-reveal-target="item">
      <span class="eyebrow center"><%= sec_text("home", "home_quotes", "eyebrow").presence || "In their words" %></span>
    </div>
    <div class="quotes reveal d1" data-reveal-target="item">
      <div class="quote">
        <span class="mark">“</span>
        <p><%= sec_text("home", "home_quotes", "quote_1").presence || "She told me what I didn't need before she told me what I did. I'd never had a doctor do that." %></p>
        <p class="by"><%= sec_text("home", "home_quotes", "by_1").presence || "L.M. · Riyadh" %></p>
      </div>
      <div class="quote">
        <span class="mark">“</span>
        <p><%= sec_text("home", "home_quotes", "quote_2").presence || "Six months, one plan, reviewed every quarter. My skin looks like mine — only rested." %></p>
        <p class="by"><%= sec_text("home", "home_quotes", "by_2").presence || "A.R. · Riyadh" %></p>
      </div>
      <div class="quote">
        <span class="mark">“</span>
        <p><%= sec_text("home", "home_quotes", "quote_3").presence || "Discreet from the first message to the last review. I never felt like a number on a calendar." %></p>
        <p class="by"><%= sec_text("home", "home_quotes", "by_3").presence || "F.K. · Riyadh" %></p>
      </div>
    </div>
  </div>
</section>
<% end %>

<%# ---- Closing CTA band ---- %>
<section class="cta-band" data-controller="reveal">
  <div class="cta-band-media reveal" data-reveal-target="item">
    <%= sec_image_tag("home", "home_cta", :lounge, alt: "The lounge at NeuSkin", class: "breathe float-delay-2") %>
  </div>
  <div class="cta-band-copy reveal d1" data-reveal-target="item">
    <h2><%= sec_text("home", "home_cta", "title").presence || "There is no rush here." %> <span class="em"><%= sec_text("home", "home_cta", "title_em").presence || "Begin with a quiet conversation." %></span></h2>
    <p><%= sec_text("home", "home_cta", "body").presence || "A private message, reviewed personally by the clinic — Saturday to Thursday, 10:00–22:00." %></p>
    <p><%= link_to (sec_text("home", "home_cta", "cta").presence || "Begin a private inquiry"), inquire_path, class: "btn" %></p>
    <p class="sign"><%= sec_text("home", "home_cta", "sign").presence || "— The NeuSkin Team" %></p>
  </div>
</section>
