<%# Private Care / VIP (design §isVip) — gated, by invitation. Discretion is the entire offer. %>

<%
  vip_includes = [
    "A standing relationship with Dr. Maysa, not a queue.",
    "Same-week scheduling, including outside published hours.",
    "Quarterly reviews with your full skin history in the room.",
    "Discreet entry and a private suite for every visit.",
    "Priority on new protocols before they are offered widely.",
    "One point of contact who already knows your file."
  ]

  vip_tiers = [
    { badge: "I", name: "Quiet", line: "The essential relationship.",
      desc: "Doctor-led care on your schedule, with quarterly reviews and a single private point of contact." },
    { badge: "II", name: "Considered", line: "For the long view.",
      desc: "Everything in Quiet, plus priority access to new protocols and an annual full reassessment." },
    { badge: "III", name: "Invited", line: "By Dr. Maysa, personally.",
      desc: "A bespoke relationship arranged case by case. Extended discretion, travel coordination, family care." }
  ]
%>

<%# Hero — landscape overlay (matches bridal-concierge) %>
<section class="over-hero" data-controller="reveal parallax">
  <div class="over-hero-media" data-parallax data-parallax-speed="0.08">
    <%= ns_image_tag :resort, alt: "Private Care", class: "kb" %>
  </div>
  <div class="over-hero-copy">
    <div class="over-hero-eyebrow reveal" data-reveal-target="item">
      <span class="rule"></span>
      <span class="eyebrow no-rule">Private Care &middot; By invitation</span>
    </div>
    <h1>
      <span class="line" data-reveal="mask" data-reveal-delay="150"><span>Private Care</span></span>
      <span class="line" data-reveal="mask" data-reveal-delay="260"><span>is by invitation.</span></span>
      <span class="line em" data-reveal="mask" data-reveal-delay="410"><span>You may already qualify.</span></span>
    </h1>
    <p class="over-hero-lead" data-reveal="up" data-reveal-delay="560">A standing relationship with Dr. Maysa — arranged privately, kept discreetly, and offered only to those we invite.</p>
  </div>
</section>

<%# What Private Care includes %>
<section class="section section--surface" data-controller="reveal">
  <div class="section-inner">
    <div class="sec-head">
      <span class="eyebrow reveal" data-reveal-target="item">What Private Care includes</span>
    </div>
    <ul class="vip-rows vip-rows--2col reveal d1" data-reveal-target="item">
      <% vip_includes.each do |item| %>
        <li><%= item %></li>
      <% end %>
    </ul>
  </div>
</section>

<%# Membership tiers %>
<section class="section" data-controller="reveal">
  <div class="section-inner">
    <div class="sec-head">
      <span class="eyebrow reveal" data-reveal-target="item">Membership tiers</span>
    </div>
    <div class="tiers">
      <% vip_tiers.each_with_index do |tier, i| %>
        <div class="tier reveal d<%= i + 1 %>" data-reveal-target="item">
          <span class="badge"><%= tier[:badge] %></span>
          <h3><%= tier[:name] %></h3>
          <div class="line"><%= tier[:line] %></div>
          <p><%= tier[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# Application — quote (left) + form (right); composes a private WhatsApp message via the vipapply controller %>
<section class="section section--surface" data-controller="reveal">
  <div class="section-inner" data-controller="vipapply">
    <div class="split apply-split">
      <%# Left — quote %>
      <div class="apply-quote reveal" data-reveal-target="item">
        <span class="eyebrow">Application</span>
        <blockquote>
          &ldquo;Discretion is not a feature here. It is the entire promise &mdash; and I keep it personally.&rdquo;
        </blockquote>
        <cite>&mdash; Dr. Maysa</cite>
        <p class="apply-note">
          Private Care has no public booking. Tell us a little, and if it is the right
          fit, we will reach out personally and privately.
        </p>
      </div>

      <%# Right — form %>
      <div class="form reveal d1" data-reveal-target="item">
        <div class="field">
          <label for="vip_name">Name</label>
          <input id="vip_name" type="text" placeholder="Your name" data-vipapply-target="name">
        </div>
        <div class="field">
          <label for="vip_contact">Contact</label>
          <input id="vip_contact" type="text" placeholder="Mobile or email" data-vipapply-target="contact">
        </div>
        <div class="field">
          <label for="vip_referral">Referral source</label>
          <input id="vip_referral" type="text" placeholder="How did you hear of us?" data-vipapply-target="referral">
        </div>
        <div class="field">
          <label for="vip_note">A brief note</label>
          <textarea id="vip_note" placeholder="Anything you'd like us to know" data-vipapply-target="note"></textarea>
        </div>
        <a class="btn" target="_blank" rel="noopener"
           href="<%= whatsapp_url(codeword: "PRIVATE") %>"
           data-vipapply-target="submit"
           data-action="vipapply#compose">
          Submit application
        </a>
      </div>
    </div>
  </div>
</section>
