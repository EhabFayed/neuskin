<%# Our Technologies — device portfolio (July 2026 content deck). Page chrome
    (hero/intro/CTA) is CMS-editable (page "technologies", sec_text idiom);
    the flip cards are Device records managed in dashboard → Devices. %>

<%# ---- Hero: vertically split composite — the deck asks for the device rooms
      side by side, with the branded shot last and slightly wider. Slices are
      the tech_hero gallery in the dashboard. %>
<% slices = sec_gallery_urls("technologies", "tech_hero", %i[treatment_room device_table lounge interior_ext]) %>
<section class="tech-hero" data-controller="reveal">
  <div class="tech-hero-slices" aria-hidden="true">
    <% slices.each do |url| %><span style="background-image:url('<%= url %>')"></span><% end %>
  </div>
  <div class="tech-hero-copy">
    <span class="eyebrow reveal" data-reveal-target="item"><%= sec_text("technologies", "tech_hero", "eyebrow").presence || "Our Technologies" %></span>
    <h1>
      <span data-reveal="mask" data-reveal-delay="120"><span><%= sec_text("technologies", "tech_hero", "title").presence || "Where Clinical Excellence" %></span></span>
      <span class="em" data-reveal="mask" data-reveal-delay="240"><span><%= sec_text("technologies", "tech_hero", "title_em").presence || "Meets Human Grace." %></span></span>
    </h1>
    <p class="lead reveal d2" data-reveal-target="item">
      <%= sec_text("technologies", "tech_hero", "sub").presence || "We believe true beauty is powered by science and defined by patience. Explore the innovative protocols that form the foundation of your NeuSkin journey." %>
    </p>
    <p class="reveal d3" data-reveal-target="item">
      <%= link_to (sec_text("technologies", "tech_hero", "cta").presence || "Explore Our Treatments"), treatments_path, class: "btn" %>
    </p>
  </div>
</section>

<%# ---- The Science of You (compact band) ---- %>
<section class="section tech-intro orn-host" data-controller="reveal">
  <%= render "shared/orn", variant: "rings", pos: "tr" %>
  <div class="section-inner">
    <div class="sec-head center reveal" data-reveal-target="item">
      <span class="eyebrow center"><%= sec_text("technologies", "tech_intro", "eyebrow").presence || "The Standard" %></span>
      <h2><%= sec_text("technologies", "tech_intro", "title").presence || "The Science of You" %></h2>
    </div>
    <p class="lead tech-intro-lead reveal d1" data-reveal-target="item">
      <%= sec_text("technologies", "tech_intro", "body").presence || "At NeuSkin, technology is a refined tool to honor your body's natural potential. We have selected a portfolio of FDA-cleared innovations that work in harmony with your physiology, prioritizing your long-term health and aesthetic goals." %>
    </p>
  </div>
</section>

<%# ---- Device flip cards: patient-facing story on the front, technical
      specs on the back. Hover flips on pointer devices (site-wide .flipcard
      CSS); the flip controller adds tap/keyboard toggling for touch.
      One card per Device record — add/edit/remove in dashboard → Devices. %>
<% if @devices.any? %>
  <section class="section section--surface" data-controller="reveal">
    <div class="section-inner">
      <div class="tech-grid reveal d1" data-reveal-target="item">
        <% @devices.each do |device| %>
          <div class="tech-card flipcard" data-controller="flip" data-action="click->flip#toggle keydown.enter->flip#toggle"
               tabindex="0" role="button" aria-pressed="false" aria-label="<%= device.name %>">
            <div class="flip-inner">
              <div class="flip-front">
                <span class="tech-media">
                  <% if device.front_image.attached? %>
                    <%= image_tag device.front_image, alt: device.name %>
                  <% else %>
                    <%= ns_image_tag :device_table, alt: device.name %>
                  <% end %>
                </span>
                <div class="tech-copy">
                  <span class="badge"><%= device.tagline %></span>
                  <h3><%= device.name %></h3>
                  <p><%= device.body %></p>
                </div>
                <svg class="flip-cue" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-2.64-6.36"/><path d="M21 3v6h-6"/></svg>
              </div>
              <div class="flip-back">
                <span class="tech-back-media" style="background-image:url('<%= device.back_image.attached? ? url_for(device.back_image) : image_path("site/space/device-room.webp") %>')"></span>
                <div class="tech-copy">
                  <span class="badge"><%= t("technologies.specs_label") %></span>
                  <h3><%= device.name %></h3>
                  <p><%= device.specs %></p>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# ---- Closing CTA ---- %>
<section class="cta-center orn-host" data-controller="reveal">
  <%= render "shared/orn", variant: "rings", pos: "halo", size: 380 %>
  <h2 class="reveal" data-reveal-target="item"><%= sec_text("technologies", "tech_cta", "title").presence || "Ready to experience the NeuSkin difference?" %> <span class="em"><%= sec_text("technologies", "tech_cta", "title_em").presence || "Your transformation begins here." %></span></h2>
  <p class="reveal d1" data-reveal-target="item"><%= link_to (sec_text("technologies", "tech_cta", "button").presence || "Book Your Consultation"), inquire_path, class: "btn" %></p>
</section>
