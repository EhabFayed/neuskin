<%# Journal (§12) — editorial magazine grid, not a blog feed. %>

<section class="section journal-hero" data-controller="reveal">
  <div class="wrap narrow" style="text-align:center">
    <span class="label reveal" data-reveal-target="item"><%= t("journal.eyebrow") %></span>
    <h1 class="journal-title reveal" data-reveal-target="item" dir="<%= loc_dir %>">
      <%= loc(ar: t("journal.title_ar"), en: t("journal.title_en")) %>
    </h1>
    <p class="journal-intro reveal" data-reveal-target="item" dir="<%= loc_dir %>">
      <%= loc(ar: t("journal.intro_ar"), en: t("journal.intro_en")) %>
    </p>
  </div>
</section>

<section class="section journal-body" data-controller="reveal">
  <div class="wrap">
    <%# Category labels — the strategy deck's content pillars. Static for now. %>
    <div class="journal-cats reveal" data-reveal-target="item">
      <% t("journal.categories").each do |cat| %>
        <span class="journal-cat"><%= cat %></span>
      <% end %>
    </div>

    <div class="journal-grid">
      <% journal_imgs = %w[site/journal/j1.jpg site/journal/j2.jpg site/journal/j3.jpg] %>
      <% t("journal.articles").each_with_index do |article, i| %>
        <article class="journal-card journal-card--<%= i % 3 %> reveal" data-reveal-target="item">
          <div class="journal-image has-photo" style="--shot-photo: url('<%= asset_path(journal_imgs[i % 3]) %>')" aria-hidden="true"></div>
          <div class="journal-card-body">
            <span class="journal-card-cat"><%= article[:category] %></span>
            <h2 class="journal-card-title" dir="<%= loc_dir %>">
              <%= loc(ar: article[:title_ar], en: article[:title_en]) %>
            </h2>
            <p class="journal-card-meta"><%= article[:byline] %> · <%= article[:reading_time] %></p>
          </div>
        </article>
      <% end %>
    </div>

    <p class="journal-note reveal" data-reveal-target="item"><%= t("journal.placeholder_note") %></p>
  </div>
</section>
