<%# Journal (design §isJournal) — editorial magazine grid, not a blog feed. %>

<%
  journal_articles = [
    { cat: "Dr. Maysa Writes", read: "6 min read",
      title: "Why I read skin before I treat it",
      excerpt: "The first appointment is diagnostic, never cosmetic. Here is what we are actually measuring, and why the order matters." },
    { cat: "Inside the Clinic", read: "4 min read",
      title: "A quiet room, by design",
      excerpt: "We built Al Malqa around discretion — separate entries, no waiting room theatre, one patient at a time." },
    { cat: "Ritual", read: "5 min read",
      title: "The three products most skin actually needs",
      excerpt: "Restraint is the most underrated skill in skincare. A short list, and the reasoning behind each choice." },
    { cat: "Dr. Maysa Writes", read: "7 min read",
      title: "Sequencing: the year, not the session",
      excerpt: "Good skin is built across quarters. How we plan twelve months so nothing is ever overwhelmed." },
    { cat: "Notes from Patients", read: "3 min read",
      title: "What changed was how I felt walking in",
      excerpt: "A patient on the difference between being sold to and being cared for — shared, with consent." },
    { cat: "Inside the Clinic", read: "5 min read",
      title: "How we say no",
      excerpt: "Turning a treatment down is part of the practice. The conversations we have when something isn't right for you." }
  ]
  journal_images = ["site/journal/j1.jpg", "site/journal/j2.jpg", "site/journal/j3.jpg"]
%>

<div class="journal-page">
  <%# Journal hero — ported 1:1 from design §isJournal %>
  <section class="jr-hero" data-controller="reveal" data-screen-label="Journal">
    <div class="jr-eyebrow reveal" data-reveal-target="item">
      <span class="rule"></span>
      <span class="lbl">The Journal</span>
    </div>
    <h1 class="jr-title" data-reveal="up">Notes, quietly<br><span class="em">kept.</span></h1>
    <p class="jr-lead" data-reveal="up" data-reveal-delay="120">
      A doctor&rsquo;s writing, the clinic from the inside, and the rituals in
      between &mdash; read at your own pace. Nothing trending, nothing rushed.
    </p>
    <div class="jr-filters" data-reveal="up" data-reveal-delay="200">
      <span class="jr-filter is-active">All</span>
      <span class="jr-filter">Dr. Maysa Writes</span>
      <span class="jr-filter">Inside the Clinic</span>
      <span class="jr-filter">Ritual</span>
      <span class="jr-filter">Notes from Patients</span>
    </div>
  </section>

  <%# Journal grid — repeat(3,1fr), 300px imagery %>
  <section class="jr-grid-wrap" data-controller="reveal">
    <div class="jr-grid">
      <% journal_articles.each_with_index do |article, i| %>
        <a class="jr-card reveal d<%= (i % 3) + 1 %>" data-reveal-target="item" href="<%= journal_path %>">
          <div class="jr-card-img">
            <%= image_tag journal_images[i % journal_images.size], alt: article[:title] %>
          </div>
          <div class="jr-card-meta">
            <span class="cat"><%= article[:cat] %></span>
            <span class="read"><%= article[:read] %></span>
          </div>
          <h3><%= article[:title] %></h3>
          <p><%= article[:excerpt] %></p>
        </a>
      <% end %>
    </div>
  </section>
</div>
