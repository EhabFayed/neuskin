<%# About — The Clinic (§02). %>

<%# 1 · Hero — clinic interior film (video if present, else photo) + overlay headline %>
<% clinic_clip = "clinic-interior.mp4" %>
<% clinic_has_clip = File.exist?(Rails.root.join("app/assets/videos", clinic_clip)) %>
<section class="clinic-hero has-photo" style="--hero-photo: url('<%= asset_path('site/space/entrance.jpg') %>')">
  <% if clinic_has_clip %>
    <video class="clinic-hero-media hero-video" autoplay muted loop playsinline poster="<%= asset_path('site/space/entrance.jpg') %>" aria-hidden="true">
      <source src="<%= asset_path(clinic_clip) %>" type="video/mp4">
    </video>
  <% else %>
    <div class="clinic-hero-media" aria-hidden="true"></div>
  <% end %>
  <div class="clinic-hero-overlay">
    <p class="clinic-overline" dir="<%= loc_dir %>"><%= loc(ar: t("clinic.hero_ar"), en: t("clinic.hero_en")) %></p>
  </div>
</section>

<%# 2 · The Story — first-person-plural editorial, signed, with logo watermark %>
<section class="section story-section" data-controller="reveal"
         style="--story-logo: url('<%= asset_path('site/logo-ns.png') %>')">
  <div class="wrap narrow essay" style="position:relative;z-index:1">
    <div class="sec-head reveal" data-reveal-target="item" style="text-align:start">
      <span class="label"><%= t("clinic.story_label") %></span>
    </div>
    <% t("clinic.story").each do |para| %>
      <p class="reveal" data-reveal-target="item"><%= para %></p>
    <% end %>
    <p class="essay-sign reveal" data-reveal-target="item" dir="rtl">— د. ميساء</p>
  </div>
</section>

<%# 3 · The Space — photographic essay (placeholders, no people) %>
<section class="section section--deep" data-controller="reveal">
  <div class="wrap">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="label"><%= t("clinic.space_label") %></span>
    </div>
    <% space_photos = { 0 => "site/lounge.jpg", 1 => "site/protocols/skin.jpg", 2 => "site/plaster-texture.jpg",
                        3 => "site/journal/j2.jpg", 4 => "site/protocols/hair.jpg", 5 => "site/desert-atmosphere.jpg" } %>
    <div class="space-grid">
      <% t("clinic.space_rooms").each_with_index do |room, i| %>
        <figure class="space-shot space-shot--<%= i % 5 %><%= " has-photo" if space_photos[i] %> reveal-img" data-reveal-target="item"
                <%= "style=\"--shot-photo: url('#{asset_path(space_photos[i])}')\"".html_safe if space_photos[i] %>>
          <figcaption><%= room %></figcaption>
        </figure>
      <% end %>
    </div>
  </div>
</section>

<%# 4 · How we work — the four-step patient journey (shared partial) %>
<%= render "shared/patient_journey" %>

<%# 5 · The Standard — compliance + credentials %>
<section class="section section--deep" data-controller="reveal">
  <div class="wrap narrow">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="label"><%= t("clinic.standard_label") %></span>
    </div>
    <ul class="standard-list">
      <% t("clinic.standard").each do |item| %>
        <li class="reveal" data-reveal-target="item" dir="<%= loc_dir %>"><%= loc(ar: item[:ar], en: item[:en]) %></li>
      <% end %>
    </ul>
  </div>
</section>

<%# 6 · CTA — shared booking band %>
<%= render "shared/book_cta", key: "clinic" %>
