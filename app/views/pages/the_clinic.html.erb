<%# About — The Clinic (§02). %>

<%# 1 · Hero — clinic interior film (placeholder loop) + overlay headline %>
<section class="clinic-hero">
  <div class="clinic-hero-media" aria-hidden="true"></div>
  <div class="clinic-hero-overlay">
    <p class="clinic-overline">
      <span class="ar" dir="rtl"><%= t("clinic.hero_ar") %></span>
      <span class="en"><%= t("clinic.hero_en") %></span>
    </p>
  </div>
</section>

<%# 2 · The Story — first-person-plural editorial, signed %>
<section class="section" data-controller="reveal">
  <div class="wrap narrow essay">
    <div class="sec-head reveal" data-reveal-target="item" style="text-align:start">
      <span class="label"><%= t("clinic.story_label") %></span>
    </div>
    <% t("clinic.story").each do |para| %>
      <p class="reveal" data-reveal-target="item"><%= para %></p>
    <% end %>
    <p class="essay-sign reveal" data-reveal-target="item" dir="rtl">— د. ميساء</p>
  </div>
</section>

<%# 3 · The Space — photographic essay (placeholders, no people) %>
<section class="section section--deep" data-controller="reveal">
  <div class="wrap">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="label"><%= t("clinic.space_label") %></span>
    </div>
    <div class="space-grid">
      <% t("clinic.space_rooms").each_with_index do |room, i| %>
        <figure class="space-shot space-shot--<%= i % 5 %> reveal" data-reveal-target="item">
          <figcaption><%= room %></figcaption>
        </figure>
      <% end %>
    </div>
  </div>
</section>

<%# 4 · How we work — the four-step patient journey (shared partial) %>
<%= render "shared/patient_journey" %>

<%# 5 · The Standard — compliance + credentials %>
<section class="section section--deep" data-controller="reveal">
  <div class="wrap narrow">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="label"><%= t("clinic.standard_label") %></span>
    </div>
    <ul class="standard-list">
      <% t("clinic.standard").each do |item| %>
        <li class="reveal" data-reveal-target="item">
          <span class="ar" dir="rtl"><%= item[:ar] %></span>
          <span class="en"><%= item[:en] %></span>
        </li>
      <% end %>
    </ul>
  </div>
</section>

<%# 6 · CTA — begin a quiet conversation %>
<section class="section section--night invite">
  <div class="wrap">
    <span class="label"><%= t("clinic.cta_label") %></span>
    <p class="line-ar" dir="rtl"><%= t("clinic.cta_ar") %></p>
    <p class="line-en"><%= t("clinic.cta_en") %></p>
    <%= link_to t("cta.private_inquiry"), inquire_path, class: "cta" %>
    <p class="codeword"><%= t("clinic.cta_note") %></p>
  </div>
</section>
