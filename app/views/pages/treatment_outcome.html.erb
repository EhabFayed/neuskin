<%# Treatment outcome — NeuSkin Clinic (standalone) design port. English / LTR.
    One template, one Treatment record per outcome — copy and image are fully
    managed in the dashboard (Admin → Treatments). %>

<%# ---- 1 · Full-bleed hero, text bottom-left (design 72vh) ---- %>
<section class="over-hero over-hero--outcome" data-controller="reveal parallax">
  <div class="over-hero-media" data-parallax data-parallax-speed="0.08">
    <%= image_tag treatment_image_url(@treatment), alt: @treatment.headline, class: "kb" %>
  </div>
  <div class="over-hero-copy over-hero-copy--wide">
    <div class="clinic-hero-eyebrow reveal" data-reveal-target="item"><%= @treatment.title %></div>
    <h1 class="clinic-hero-title" data-reveal="up"><%= @treatment.headline %></h1>
  </div>
</section>

<%# ---- 2 · What it looks like / how NeuSkin treats it ---- %>
<section class="section section--surface" data-controller="reveal">
  <div class="section-inner split">
    <div class="split-text reveal" data-reveal-target="item">
      <span class="eyebrow"><%= t("treatments.look_eyebrow", default: "What it looks like") %></span>
      <p class="lead"><%= @treatment.look %></p>
    </div>
    <div class="split-text reveal d1" data-reveal-target="item">
      <span class="eyebrow"><%= t("treatments.how_eyebrow", default: "How NeuSkin treats it") %></span>
      <p><%= @treatment.how %></p>
    </div>
  </div>
</section>

<%# ---- 3 · The protocol that owns this (light band) ---- %>
<% if @protocol %>
  <section class="section section--light" data-controller="reveal">
    <div class="section-inner" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:30px">
      <div class="reveal" data-reveal-target="item">
        <span class="eyebrow"><%= t("treatments.owner_eyebrow", default: "The protocol that owns this") %></span>
        <h2 style="margin:14px 0 0"><%= @protocol.name %><% if @protocol.trademark %><span class="tm">™</span><% end %></h2>
      </div>
      <%= link_to "View the protocol →", protocol_path(@protocol),
                  class: "btn btn--rose reveal d1", data: { reveal_target: "item" } %>
    </div>
  </section>
<% end %>

<%# ---- 4 · Dr. Maysa's view + closing CTA ---- %>
<% if @treatment.view.present? %>
  <section class="pull-band orn-host" data-controller="reveal">
    <%= render "shared/orn", variant: "petal", pos: "tl", size: 220 %>
    <span class="eyebrow center no-rule reveal" data-reveal-target="item" style="margin-block-end:34px">Dr. Maysa's view</span>
    <blockquote class="reveal d1" data-reveal-target="item">“<%= @treatment.view %>”</blockquote>
    <p class="by reveal d2" data-reveal-target="item">— Maysa</p>
    <p class="reveal d3" data-reveal-target="item" style="margin-block-start:50px">
      <%= link_to "Begin with a private inquiry", inquire_path, class: "btn btn--ghost" %>
    </p>
  </section>
<% end %>
