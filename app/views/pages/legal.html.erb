<%# Shared legal page (§15). `doc` selects the i18n namespace: privacy / medical_disclaimer / terms. %>

<section class="section legal-hero" data-controller="reveal">
  <div class="wrap narrow">
    <span class="label reveal" data-reveal-target="item"><%= t("legal.eyebrow") %></span>
    <h1 class="legal-title reveal" data-reveal-target="item" dir="<%= loc_dir %>">
      <%= loc(ar: t("legal.#{doc}.title_ar"), en: t("legal.#{doc}.title_en")) %>
    </h1>
    <p class="legal-meta reveal" data-reveal-target="item"><%= t("legal.last_updated") %></p>
  </div>
</section>

<section class="section legal-body" data-controller="reveal">
  <div class="wrap narrow">
    <%# Draft notice — these policies must be reviewed by a Saudi legal advisor before launch. %>
    <aside class="legal-notice reveal" data-reveal-target="item" dir="<%= loc_dir %>">
      <%= loc(ar: t("legal.draft_notice_ar"), en: t("legal.draft_notice_en")) %>
    </aside>

    <% t("legal.#{doc}.sections").each do |sec| %>
      <div class="legal-section reveal" data-reveal-target="item" dir="<%= loc_dir %>">
        <h2>
          <%= loc(ar: sec[:heading_ar], en: sec[:heading_en]) %>
        </h2>
        <p><%= loc(ar: sec[:body_ar], en: sec[:body_en]) %></p>
      </div>
    <% end %>

    <p class="legal-contact reveal" data-reveal-target="item" dir="<%= loc_dir %>">
      <%= loc(ar: t("legal.contact_ar"), en: t("legal.contact_en")) %>
    </p>
  </div>
</section>
