<%# Journal article — quiet editorial single-column read. %>
<% content_for :title, "#{@blog.meta_title.presence || @blog.title} — NeuSkin Clinic" %>
<% content_for :meta_description, @blog.meta_description.presence || @blog.excerpt %>

<article class="jra" data-controller="reveal">
  <%# Split hero — copy on one side, the post's cover on the other. The cover
      is the SAME image the card shows on the Journal grid (attachment or
      rotating fallback) until the content team decides articles get their
      own inside imagery. %>
  <div class="jra-hero">
    <header class="jra-head">
      <div class="jr-eyebrow reveal" data-reveal-target="item">
        <span class="rule"></span>
        <span class="lbl"><%= @blog.category_label %></span>
        <span class="lbl faint">· <%= t("journal.read", count: @blog.reading_minutes) %></span>
      </div>
      <h1 class="jr-title jra-title" data-reveal="up"><%= @blog.title %></h1>
      <% if @blog.excerpt.present? %>
        <p class="jr-lead" data-reveal="up" data-reveal-delay="120"><%= @blog.excerpt %></p>
      <% end %>
      <p class="jra-date" data-reveal="fade" data-reveal-delay="200"><%= @blog.created_at.strftime("%d.%m.%Y") %></p>
    </header>
    <figure class="jra-hero-media" data-reveal="scale">
      <%= image_tag journal_cover_source(@blog), alt: @blog.alt.presence || @blog.title %>
    </figure>
  </div>

  <div class="jra-body body-copy">
    <% @blog.contents.each do |block| %>
      <% if block.value.present? %><p><%= block.value %></p><% end %>
      <% if block.photo.attached? %>
        <figure class="jra-figure">
          <%= image_tag block.photo, alt: block.alt.to_s %>
          <% if block.alt.present? %><figcaption><%= block.alt %></figcaption><% end %>
        </figure>
      <% end %>
    <% end %>
  </div>

  <footer class="jra-foot">
    <%= link_to t("journal.back"), journal_path, class: "arrowlink" %>
  </footer>
</article>
