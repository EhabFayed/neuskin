<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>NeuSkin Studio<%= " — #{content_for(:title)}" if content_for?(:title) %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,300;0,6..96,400;0,6..96,500&family=Hanken+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "admin", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="admin">
    <span class="ns-glow tl"></span>
    <span class="ns-glow br"></span>

    <div class="ns-shell">
      <aside class="ns-aside">
        <a href="<%= admin_root_path %>" class="ns-brand">
          <span class="mark">N</span>
          <span>
            <span class="name">NeuSkin</span>
            <span class="kicker">Studio · Content</span>
          </span>
        </a>

        <nav class="ns-navgroup">
          <div class="label">Workspace</div>

          <%= link_to admin_root_path, class: "ns-navitem #{'active' if admin_nav == :overview}" do %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            <span class="grow">Overview</span>
          <% end %>

          <%= link_to admin_pages_path, class: "ns-navitem #{'active' if admin_nav == :pages}" do %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 4h11l5 5v11a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z"/><path d="M14 4v6h6"/><path d="M8 13h8M8 17h8"/></svg>
            <span class="grow">Pages</span>
            <% if defined?(@nav_pages_count) && @nav_pages_count %><span class="count"><%= @nav_pages_count %></span><% end %>
          <% end %>

          <%= link_to admin_blogs_path, class: "ns-navitem #{'active' if admin_nav == :blogs}" do %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 20l8-8-4-4-8 8v4z"/><path d="M16 8l-3-3"/><path d="M4 20h5"/></svg>
            <span class="grow">Journal</span>
            <% if defined?(@nav_blogs_count) && @nav_blogs_count %><span class="count"><%= @nav_blogs_count %></span><% end %>

          <%= link_to admin_team_members_path, class: "ns-navitem #{'active' if admin_nav == :team_members}" do %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span class="grow">Team</span>
            <% if defined?(@nav_team_count) && @nav_team_count %><span class="count"><%= @nav_team_count %></span><% end %>

          <%= link_to admin_faqs_path, class: "ns-navitem #{'active' if admin_nav == :faqs}" do %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <span class="grow">FAQ</span>
            <% if defined?(@nav_faq_count) && @nav_faq_count %><span class="count"><%= @nav_faq_count %></span><% end %>
          <% end %>
          <% end %>
          <% end %>

          <div class="ns-navitem soon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 6h12M8 12h12M8 18h12"/><circle cx="4" cy="6" r="1.4"/><circle cx="4" cy="12" r="1.4"/><circle cx="4" cy="18" r="1.4"/></svg>
            <span class="grow">Protocols</span><span class="soon-tag">Soon</span>
          </div>

          <div class="ns-navitem soon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 15l5-5 4 4 3-3 6 6"/><circle cx="9" cy="9" r="1.5"/></svg>
            <span class="grow">Media</span><span class="soon-tag">Soon</span>
          </div>
        </nav>

        <nav class="ns-navgroup">
          <div class="label">Account</div>
          <div class="ns-navitem soon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            <span class="grow">Settings</span><span class="soon-tag">Soon</span>
          </div>
        </nav>

        <% if user_signed_in? %>
          <div class="ns-userchip">
            <span class="avatar"><%= current_user.email.to_s[0].to_s.upcase %></span>
            <span class="who">
              <span class="nm"><%= current_user.email %></span>
              <span class="role"><%= current_user.role.to_s.titleize %></span>
            </span>
            <%= button_to destroy_user_session_path, method: :delete, class: "signout", form: { class: "" } do %>Sign out<% end %>
          </div>
        <% end %>
      </aside>

      <main class="ns-main">
        <header class="ns-header">
          <div class="titles">
            <div class="crumb"><%= content_for?(:crumb) ? content_for(:crumb) : "NeuSkin Studio" %></div>
            <h1><%= content_for?(:heading) ? content_for(:heading) : "Overview" %></h1>
          </div>
          <div class="actions">
            <a href="<%= root_path %>" target="_blank" rel="noopener" class="ns-viewsite">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><path d="M15 3h6v6"/><path d="M10 14L21 3"/></svg>
              View site
            </a>
          </div>
        </header>

        <% if notice %><p class="ns-flash notice"><%= notice %></p><% end %>
        <% if alert %><p class="ns-flash alert"><%= alert %></p><% end %>

        <div class="ns-content">
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
