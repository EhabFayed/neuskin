<%# Bridal Concierge — NeuSkin Clinic (standalone) design port. English / LTR. %>

<%# 1 · Split hero + wedding-date countdown ---- %>
<section class="split-hero" data-controller="countdown reveal parallax"
         data-countdown-ample-value="There is ample time to plan calmly, in the right order."
         data-countdown-ideal-value="An ideal window — the Bride's 180 fits beautifully."
         data-countdown-soon-value="Close, but workable — we'll prioritise what matters most."
         data-countdown-today-value="Let's speak today — we'll make the most of every week."
         data-countdown-days-label-value="days to plan, calmly.">
  <div class="split-hero-media reveal" data-reveal-target="item" data-parallax data-parallax-speed="0.08">
    <%= ns_image_tag :bride_bouquet, alt: "Bridal", class: "kb" %>
  </div>
  <div class="split-hero-copy">
    <span class="eyebrow reveal" data-reveal-target="item">Bridal Concierge</span>
    <h1>
      <span data-reveal="mask" data-reveal-delay="120"><span>Your skin, six months</span></span>
      <span class="em" data-reveal="mask" data-reveal-delay="240"><span>before you say yes.</span></span>
    </h1>
    <div class="date-ask reveal d2" data-reveal-target="item">
      <label for="wedding-date">Tell us your wedding date</label>
      <input type="date" id="wedding-date"
             data-countdown-target="input" data-action="change->countdown#change">
      <div class="countdown" data-countdown-target="output" hidden>
        <span class="countdown-days" data-countdown-target="days"></span>
        <span class="countdown-msg" data-countdown-target="message"></span>
      </div>
    </div>
  </div>
</section>

<%# 2 · The Bride's 180 — three-stage timeline ---- %>
<section class="section section--surface" data-controller="reveal">
  <div class="section-inner">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="eyebrow">The Bride's 180</span>
      <h2>Six months, planned in the right order — so nothing is rushed at the end.</h2>
    </div>
    <div class="cols cols-3 reveal d1" data-reveal-target="item">
      <div class="col">
        <span class="num">Months 1–2</span>
        <h3>Foundation</h3>
        <p>Diagnose, calm and correct. The slow, invisible work that everything later depends on.</p>
      </div>
      <div class="col">
        <span class="num">Months 3–4</span>
        <h3>Build</h3>
        <p>Glow, contour and hair density — sequenced, then reviewed against where you began.</p>
      </div>
      <div class="col">
        <span class="num">Months 5–6</span>
        <h3>Polish &amp; lock</h3>
        <p>Refinement, then a no-experiments rule. The last fortnight is for rest, not risk.</p>
      </div>
    </div>
  </div>
</section>

<%# 3 · Planned / Flexible / Locked ---- %>
<section class="section" data-controller="reveal">
  <div class="section-inner">
    <div class="cols cols-3 reveal" data-reveal-target="item">
      <div class="col">
        <h3>Planned</h3>
        <p>Every step mapped to your date, so the work happens early and gently.</p>
      </div>
      <div class="col">
        <h3>Flexible</h3>
        <p>Room to adjust as your skin responds — reviewed, never improvised.</p>
      </div>
      <div class="col">
        <h3>Locked</h3>
        <p>No new treatments in the final two weeks. The plan closes, and you simply arrive.</p>
      </div>
    </div>
  </div>
</section>

<%# 4 · Three bride quotes ---- %>
<section class="section section--surface" data-controller="reveal">
  <div class="section-inner">
    <div class="quotes reveal" data-reveal-target="item">
      <div class="quote">
        <span class="mark">“</span>
        <p>Everything was decided months before. The last week, I just slept.</p>
        <p class="by">L.M. · 2024</p>
      </div>
      <div class="quote">
        <span class="mark">“</span>
        <p>No one could point to one thing. I just looked like myself, rested.</p>
        <p class="by">A.R. · 2025</p>
      </div>
      <div class="quote">
        <span class="mark">“</span>
        <p>My mother started her own quiet plan beside mine. We came together.</p>
        <p class="by">F.K. · 2025</p>
      </div>
    </div>
  </div>
</section>

<%# 5 · For the mother & sister of the bride ---- %>
<section class="section" data-controller="reveal">
  <div class="section-inner">
    <div class="sec-head-row reveal" data-reveal-target="item">
      <div class="sec-head" style="margin:0">
        <span class="eyebrow no-rule" style="font-family:var(--serif);font-style:italic;text-transform:none;letter-spacing:0;font-size:24px">For the mother &amp; sister of the bride.</span>
        <p class="body-copy" style="margin-top:16px;max-width:520px"><span>A quiet parallel plan, arranged with the same discretion. Ask us during your consultation.</span></p>
      </div>
      <a class="arrowlink" href="<%= whatsapp_url(codeword: "BRIDE") %>" target="_blank" rel="noopener">Ask privately →</a>
    </div>
  </div>
</section>

<%# 6 · Bridal checklist lead form (existing flow) ---- %>
<section class="section section--surface" data-controller="reveal">
  <div class="section-inner" style="max-width:560px">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="eyebrow">The 6-month bridal checklist</span>
      <h2>A quiet plan, sent to your inbox.</h2>
    </div>
    <% if params[:checklist] == "sent" %>
      <p class="lead reveal" data-reveal-target="item">Thank you — your checklist is on its way.</p>
    <% else %>
      <%= form_with model: @lead, url: bridal_checklist_path, method: :post, class: "form reveal", data: { reveal_target: "item" } do |f| %>
        <% if @lead.errors.any? %>
          <div class="form-errors"><% @lead.errors.full_messages.each do |m| %><p><%= m %></p><% end %></div>
        <% end %>
        <div class="form-row">
          <div class="field">
            <%= f.label :email, "Your email" %>
            <%= f.email_field :email, required: true, placeholder: "you@example.com" %>
          </div>
        </div>
        <%= f.submit "Send me the checklist", class: "btn" %>
      <% end %>
      <p class="note reveal" data-reveal-target="item" style="margin-top:16px">One email. No list, no follow-ups you didn't ask for.</p>
    <% end %>
  </div>
</section>

<%# 7 · Final CTA — codeword BRIDE ---- %>
<section class="cta-center" data-controller="reveal">
  <h2 class="reveal" data-reveal-target="item">Request your Bride's 180 plan.</h2>
  <p class="reveal d1" data-reveal-target="item">Send the codeword <strong>BRIDE</strong> on WhatsApp.</p>
  <p class="reveal d2" data-reveal-target="item">
    <a class="btn" href="<%= whatsapp_url(codeword: "BRIDE") %>" target="_blank" rel="noopener">Begin the conversation</a>
  </p>
</section>
