<%# Site-wide cookie consent banner (§15), PDPL-aligned. Hidden until JS confirms
    no prior choice is stored, so it never flashes for returning visitors. %>
<div class="cookie-banner" data-controller="cookie" data-cookie-target="banner" hidden>
  <p><%= t("layout.cookie.text") %></p>
  <div class="row">
    <%= link_to t("layout.cookie.privacy"), privacy_path %>
    <button type="button" class="cookie-btn" data-action="cookie#accept"><%= t("layout.cookie.accept") %></button>
    <button type="button" class="cookie-btn" data-action="cookie#decline"><%= t("layout.cookie.essential") %></button>
  </div>
</div>
