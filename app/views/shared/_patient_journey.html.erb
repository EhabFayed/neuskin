<%# The four-step patient journey — consistent language across the whole site. %>
<section class="section journey" data-controller="reveal">
  <div class="wrap">
    <div class="sec-head reveal" data-reveal-target="item">
      <span class="label"><%= t("journey.label") %></span>
    </div>
    <ol class="journey-steps reveal" data-reveal-target="item">
      <% %w[inquire consult plan treat].each_with_index do |step, i| %>
        <li class="journey-step reveal" data-reveal-target="item">
          <span class="num"><%= format("%02d", i + 1) %></span>
          <h3 dir="<%= loc_dir %>">
            <%= loc(ar: t("journey.#{step}.title_ar"), en: t("journey.#{step}.title_en")) %>
          </h3>
          <p><%= t("journey.#{step}.body") %></p>
        </li>
      <% end %>
    </ol>
  </div>
</section>
