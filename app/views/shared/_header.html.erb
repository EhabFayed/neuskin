<header class="site-header" data-controller="header">
  <%= link_to root_path, class: "brand" do %>
    <span class="mark"><%= t("brand.name") %></span>
    <span class="sub"><%= t("brand.city") %></span>
  <% end %>

  <nav class="site-nav">
    <%= link_to t("nav.clinic"),    the_clinic_path %>
    <%= link_to t("nav.doctor"),    dr_maysa_path %>
    <%= link_to t("nav.protocols"), protocols_path %>
    <%= link_to t("nav.stories"),   stories_path %>
    <%= link_to t("nav.journal"),   journal_path %>
  </nav>

  <div class="header-actions">
    <a class="wa-icon" href="<%= whatsapp_url %>" target="_blank" rel="noopener" aria-label="WhatsApp" title="<%= t("cta.whatsapp") %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <path d="M3 21l1.6-4.5A8.4 8.4 0 1 1 8 19.4L3 21z"></path>
      </svg>
    </a>
    <%# Language toggle: link to the same page in the other locale. %>
    <% other = I18n.locale == :ar ? :en : :ar %>
    <%= link_to "AR ⇄ EN", root_path(locale: (other == I18n.default_locale ? nil : other)), class: "lang-toggle" %>
    <%= link_to t("cta.inquire"), inquire_path, class: "btn-inquire" %>
  </div>
</header>
