<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <%= image_tag "site/logo-ns.png", class: "brand-logo", alt: "NeuSkin Clinic" %>
        <p class="blurb"><%= t("layout.footer.blurb") %></p>
        <div class="footer-socials">
          <a href="#">Instagram</a>
          <a href="<%= whatsapp_url %>" target="_blank" rel="noopener"><%= t("layout.footer.whatsapp") %></a>
        </div>
      </div>

      <div>
        <h4><%= t("layout.footer.clinic_title") %></h4>
        <ul>
          <li><%= link_to t("layout.footer.about"), the_clinic_path %></li>
          <%# Dr. Maysa link hidden with the page (July 2026 content deck). %>
          <li><%= link_to t("layout.footer.team"), the_team_path %></li>
          <li><%= link_to t("layout.footer.method"), neuskin_method_path %></li>
        </ul>
      </div>

      <div>
        <h4><%= t("layout.footer.protocols_title") %></h4>
        <ul>
          <li><%= link_to t("layout.footer.all_protocols"), protocols_path %></li>
          <li><%= link_to t("layout.footer.treatments"), treatments_path %></li>
          <li><%= link_to t("layout.footer.technologies"), technologies_path %></li>
          <li><%= link_to t("layout.footer.bridal"), bridal_concierge_path %></li>
          <li><%= link_to t("layout.footer.private_care"), private_care_path %></li>
        </ul>
      </div>

      <div>
        <h4><%= t("layout.footer.care_title") %></h4>
        <ul>
          <li><%= link_to t("layout.footer.journal"), journal_path %></li>
          <li><%= link_to t("layout.footer.stories"), stories_path %></li>
          <li><%= link_to t("layout.footer.faq"), faq_path %></li>
          <li><%= link_to t("layout.footer.contact"), inquire_path %></li>
        </ul>
      </div>

      <div class="footer-visit">
        <h4><%= t("layout.footer.visit_title") %></h4>
        <p><%= t("layout.footer.address_1") %><br><%= t("layout.footer.address_2") %></p>
        <p><%= t("layout.footer.hours_1") %><br><%= t("layout.footer.hours_2") %></p>
        <p><%= link_to t("layout.footer.whatsapp"), whatsapp_url, target: "_blank", rel: "noopener" %><br>
           <a href="mailto:hello@neuskin.sa" dir="ltr">hello@neuskin.sa</a></p>
      </div>
    </div>

    <div class="footer-bottom">
      <span><%= t("layout.footer.copyright", year: Time.current.year) %></span>
      <nav class="footer-bottom-nav" aria-label="Legal">
        <%= link_to t("layout.footer.legal_privacy"), privacy_path %>
        <%= link_to t("layout.footer.legal_consent"), medical_disclaimer_path %>
        <%= link_to t("layout.footer.legal_terms"), terms_path %>
      </nav>
    </div>
  </div>
</footer>
