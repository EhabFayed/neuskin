<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <%= image_tag "site/logo-ns.png", class: "brand-logo", alt: "NeuSkin Clinic" %>
        <p class="blurb">Doctor-led skin intelligence for women, in the quiet of Al Malqa, Riyadh.</p>
        <div class="footer-socials">
          <a href="#">Instagram</a>
          <a href="<%= whatsapp_url %>" target="_blank" rel="noopener">WhatsApp</a>
        </div>
      </div>

      <div>
        <h4>The Clinic</h4>
        <ul>
          <li><%= link_to "About", the_clinic_path %></li>
          <li><%= link_to "Dr. Maysa", dr_maysa_path %></li>
          <li><%= link_to "The Medical Team", the_team_path %></li>
          <li><%= link_to "The Maysa Method™", maysa_method_path %></li>
        </ul>
      </div>

      <div>
        <h4>Protocols</h4>
        <ul>
          <li><%= link_to "All Protocols", protocols_path %></li>
          <li><%= link_to "Treatments", treatments_path %></li>
          <li><%= link_to "Bridal Concierge", bridal_concierge_path %></li>
          <li><%= link_to "Private Care", private_care_path %></li>
        </ul>
      </div>

      <div>
        <h4>Care</h4>
        <ul>
          <li><%= link_to "Journal", journal_path %></li>
          <li><%= link_to "Patient Stories", stories_path %></li>
          <li><%= link_to "FAQ", faq_path %></li>
          <li><%= link_to "Contact", inquire_path %></li>
        </ul>
      </div>

      <div class="footer-visit">
        <h4>Visit</h4>
        <p>Al Malqa, Riyadh<br>Kingdom of Saudi Arabia</p>
        <p>Sat–Thu · 10:00–22:00<br>Friday · Closed</p>
        <p><%= link_to "WhatsApp", whatsapp_url, target: "_blank", rel: "noopener" %><br>
           <a href="mailto:hello@neuskin.sa">hello@neuskin.sa</a></p>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© <%= Time.current.year %> NeuSkin Clinic · SFDA / MOH licensed</span>
      <nav class="footer-bottom-nav" aria-label="Legal">
        <%= link_to "Privacy & PDPL", privacy_path %>
        <%= link_to "Consent", medical_disclaimer_path %>
        <%= link_to "Terms", terms_path %>
      </nav>
    </div>
  </div>
</footer>
