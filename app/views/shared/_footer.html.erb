<footer class="site-footer">
  <div class="wrap">
    <div class="footer-cols">
      <div class="footer-brand">
        <%= image_tag "site/logo-ns.png", class: "footer-logo", alt: t("brand.name") %>
        <p class="pos"><%= t("brand.positioning") %></p>
        <div class="socials">
          <a href="#">IG</a><a href="#">SNAP</a><a href="#">TIKTOK</a><a href="#">YT</a>
        </div>
      </div>

      <div>
        <h4><%= t("footer.clinic") %></h4>
        <ul>
          <li><%= link_to t("footer.about"),  the_clinic_path %></li>
          <li><%= link_to t("nav.doctor"),    dr_maysa_path %></li>
          <li><%= link_to t("footer.team"),   the_team_path %></li>
          <li><%= link_to t("footer.method"), maysa_method_path %></li>
        </ul>
      </div>

      <div>
        <h4><%= t("footer.care") %></h4>
        <ul>
          <li><%= link_to t("nav.protocols"),       protocols_path %></li>
          <li><%= link_to t("footer.bridal"),       bridal_concierge_path %></li>
          <li><%= link_to t("footer.private_care"), private_care_path %></li>
          <li><%= link_to t("nav.journal"),         journal_path %></li>
          <li><%= link_to t("nav.stories"),         stories_path %></li>
          <li><%= link_to t("footer.faq"),          faq_path %></li>
        </ul>
      </div>

      <div>
        <h4><%= t("footer.contact") %></h4>
        <ul>
          <li><%= t("footer.address") %></li>
          <li><%= t("footer.hours") %></li>
          <li><%= link_to "WhatsApp", whatsapp_url, target: "_blank", rel: "noopener" %></li>
          <li><%= link_to t("cta.inquire"), inquire_path %></li>
        </ul>
      </div>
    </div>

    <nav class="footer-legal" aria-label="Legal">
      <%= link_to t("footer.legal.privacy"),    privacy_path %>
      <%= link_to t("footer.legal.disclaimer"), medical_disclaimer_path %>
      <%= link_to t("footer.legal.terms"),      terms_path %>
    </nav>

    <div class="subfoot">
      <span><%= t("footer.disclaimer") %></span>
      <span><%= t("footer.license") %></span>
    </div>
  </div>
</footer>
