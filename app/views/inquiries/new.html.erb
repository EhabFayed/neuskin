<%# Contact & Inquiry (design §isContact) — two-path layout + private form. %>

<section class="page-hero" data-controller="reveal" style="text-align:center">
  <span class="eyebrow center reveal" data-reveal-target="item">Contact &middot; Inquiry</span>
  <h1 style="margin-inline:auto">
    <span data-reveal="mask" data-reveal-delay="120"><span>Begin a quiet</span></span>
    <span class="em" data-reveal="mask" data-reveal-delay="240"><span>conversation.</span></span>
  </h1>
</section>

<section class="section section--surface" data-controller="reveal">
  <div class="section-inner">
    <div class="paths">

      <%# Path A — WhatsApp %>
      <div class="path reveal" data-reveal-target="item">
        <span class="ptag">Path A &middot; Preferred</span>
        <h3>Speak privately on WhatsApp</h3>
        <p>
          The fastest, quietest way to reach us. Send the codeword for the
          protocol you&rsquo;re curious about &mdash; or simply say hello.
        </p>
        <a class="btn" href="<%= whatsapp_url(codeword: @inquiry.source_codeword) %>" target="_blank" rel="noopener">
          Speak privately on WhatsApp
        </a>
        <p class="path-phone">+966 50 000 0000</p>
      </div>

      <%# Path B — private form %>
      <div class="path reveal d1" data-reveal-target="item">
        <span class="ptag">Path B &middot; Private form</span>

        <% if @inquiry.errors.any? %>
          <div class="form-errors" style="margin-block:18px 0">
            <% @inquiry.errors.full_messages.each do |message| %>
              <p><%= message %></p>
            <% end %>
          </div>
        <% end %>

        <%= form_with model: @inquiry, url: inquire_path, method: :post, class: "form" do |f| %>
          <%= f.hidden_field :source_codeword %>
          <%= f.hidden_field :persona %>

          <div class="form-row">
            <div class="field">
              <%= f.label :name, "Name" %>
              <%= f.text_field :name, placeholder: "Your name" %>
            </div>
            <div class="field" data-controller="phone">
              <%= f.label :mobile, "Mobile" %>
              <div class="mobile-field">
                <span class="prefix">+966</span>
                <%= f.text_field :mobile, placeholder: "5X XXX XXXX", inputmode: "tel",
                      data: { phone_target: "input", action: "input->phone#format" } %>
              </div>
            </div>
          </div>

          <div class="field">
            <%= f.label :email, "Email" %>
            <%= f.email_field :email, placeholder: "you@example.com" %>
          </div>

          <div class="field">
            <%= f.label :persona, "What brings you here?" %>
            <%= f.select :persona,
                  options_for_select([
                    ["Tired, dull skin", "tired"],
                    ["Hair & shedding", "hair"],
                    ["Bridal — a wedding ahead", "bride"],
                    ["Body, tone & contour", "maintain"],
                    ["Long-term maintenance", "maintain"],
                    ["I'm not sure yet", "unsure"]
                  ], @inquiry.persona),
                  { include_blank: "What brings you here?" } %>
          </div>

          <div class="field">
            <%= f.label :preferred_time, "Preferred contact time" %>
            <%= f.select :preferred_time,
                  options_for_select(%w[Morning Afternoon Evening], @inquiry.preferred_time),
                  { include_blank: "Preferred contact time" } %>
          </div>

          <%= f.submit "Send inquiry", class: "btn" %>
        <% end %>
      </div>

    </div>
  </div>
</section>

<%# Trust strip %>
<section class="section" data-controller="reveal">
  <div class="section-inner">
    <div class="trust">
      <div class="reveal" data-reveal-target="item">
        <h4>Within 2 hours</h4>
        <p>Every inquiry is reviewed by our patient relations lead within two hours during business hours.</p>
      </div>
      <div class="reveal d1" data-reveal-target="item">
        <h4>Al Malqa, Riyadh</h4>
        <p>Saturday&ndash;Thursday &middot; 10:00&ndash;22:00. Friday closed. Exact address shared on scheduling.</p>
      </div>
      <div class="reveal d2" data-reveal-target="item">
        <h4>Seen by two</h4>
        <p>Your inquiry is reviewed only by our patient relations lead and your treating doctor. Nowhere else.</p>
      </div>
    </div>
  </div>
</section>
