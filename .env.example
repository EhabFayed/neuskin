# Copy to .env and fill in. .env is gitignored — never commit real values.
# Development works with everything left empty (mail is logged, not sent).
# On the SERVER, set these in the stack's env (compose env_file / stack.env).

# ---- Mail (required in production for lead emails) ----
# SMTP provider credentials (Brevo / Mailgun / SES / etc — STARTTLS on 587).
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Where "new lead" notifications are delivered.
CLINIC_INFO_EMAIL=info@milaknights.com
# The From: address on all outgoing mail — must be on a domain your SMTP
# provider has verified, or mail lands in spam.
MAIL_FROM="NeuSkin Clinic <no-reply@example.com>"
# Public host, used for links inside emails (no scheme).
APP_HOST=

# ---- Clinic contact ----
# WhatsApp number, digits only, international format, no "+".
WHATSAPP_NUMBER=966500000000

# ---- Admin bootstrap (used by db:seed) ----
ADMIN_EMAIL=admin@neuskin.test
# REQUIRED in production before seeding; dev falls back to changeme123.
ADMIN_PASSWORD=
